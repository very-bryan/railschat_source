async function addReaction(messageId, emoji) {
  document.getElementById('emojiPicker').classList.add('hidden');
  
  try {
    // Optimistically update UI first
    const messageElement = document.getElementById(`message-${messageId}`);
    let reactionsContainer = messageElement.querySelector('.flex.flex-wrap.gap-2.mt-2');
    
    if (reactionsContainer) {
      // Find existing reaction button for this emoji
      const existingButton = Array.from(reactionsContainer.querySelectorAll('button')).find(btn => 
        btn.textContent.includes(emoji)
      );
      
      if (existingButton) {
        // Update count
        const countSpan = existingButton.querySelector('.font-medium');
        const currentCount = parseInt(countSpan.textContent);
        countSpan.textContent = currentCount + 1;
      } else {
        // Add new reaction with proper structure
        const reactionDiv = document.createElement('div');
        reactionDiv.className = 'relative group/reaction';
        
        const newButton = document.createElement('button');
        newButton.className = 'inline-flex items-center gap-1 hover:scale-110 transition-transform';
        newButton.setAttribute('onclick', `toggleReaction('${messageId}', '${emoji}')`);
        const emojiSpan = document.createElement('span');
        emojiSpan.className = 'text-xl';
        emojiSpan.textContent = emoji;
        const countSpan = document.createElement('span');
        countSpan.className = 'text-xs font-medium text-slate-500';
        countSpan.textContent = '1';
        newButton.appendChild(emojiSpan);
        newButton.appendChild(countSpan);
        
        reactionDiv.appendChild(newButton);
        reactionsContainer.appendChild(reactionDiv);
      }
    } else {
      // Create reactions container if it doesn't exist
      const newContainer = document.createElement('div');
      newContainer.className = 'flex flex-wrap gap-2 mt-2';
      
      const reactionDiv = document.createElement('div');
      reactionDiv.className = 'relative group/reaction';
      
      const newButton = document.createElement('button');
      newButton.className = 'inline-flex items-center gap-1 hover:scale-110 transition-transform';
      newButton.setAttribute('onclick', `toggleReaction('${messageId}', '${emoji}')`);
      const emojiSpan2 = document.createElement('span');
      emojiSpan2.className = 'text-xl';
      emojiSpan2.textContent = emoji;
      const countSpan2 = document.createElement('span');
      countSpan2.className = 'text-xs font-medium text-slate-500';
      countSpan2.textContent = '1';
      newButton.appendChild(emojiSpan2);
      newButton.appendChild(countSpan2);
      
      reactionDiv.appendChild(newButton);
      newContainer.appendChild(reactionDiv);
      messageElement.querySelector('.flex-1.min-w-0').appendChild(newContainer);
    }
    
    const response = await fetch(`/messages/${messageId}/reactions/toggle`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      },
      body: JSON.stringify({ emoji: emoji })
    });
    
    if (!response.ok) {
      console.error('Failed to add reaction');
      // Only reload if there was an actual error
      window.location.reload();
    }
  } catch (error) {
    console.error('Error:', error);
    // Only reload if there was an actual error
    window.location.reload();
  }
}

async function toggleReaction(messageId, emoji) {
  try {
    // Send request to server immediately - let server handle the update
    const response = await fetch(`/messages/${messageId}/toggle_reaction`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-CSRF-Token": document.querySelector("[name='csrf-token']").content
      },
      body: JSON.stringify({ emoji: emoji })
    });
    
    if (!response.ok) {
      console.error("Error toggling reaction");
      showToast("이모지 반응 중 오류가 발생했습니다");
    }
    // The server will send a Turbo Stream or Action Cable update
  } catch (error) {
    console.error("Error toggling reaction:", error);
    showToast("이모지 반응 중 오류가 발생했습니다");
  }
}

function replyToMessage(messageId, userName) {
  // Find the message input field (could be input or textarea)
  const messageInput = document.querySelector('textarea[name="message[body]"]') || document.querySelector('input[name="message[body]"]');
  const parentMessageIdField = document.getElementById('parent_message_id');
  
  if (messageInput) {
    // Set the parent message ID in the hidden field
    if (parentMessageIdField) {
      parentMessageIdField.value = messageId;
    }
    
    // Also set it as data attribute for backward compatibility
    messageInput.dataset.replyToId = messageId;
    messageInput.focus();
    
    // Adjust height if it's a textarea
    if (messageInput.tagName === 'TEXTAREA') {
      adjustTextareaHeight(messageInput);
    }
    
    // Show visual indicator that we're replying
    const replyIndicator = document.createElement('div');
    replyIndicator.id = 'replyIndicator';
    replyIndicator.className = 'mb-2 px-3 py-2 bg-slate-100 rounded-lg flex items-center justify-between text-sm';
    replyIndicator.innerHTML = `
      <span class="text-slate-600">
        <span class="text-purple-600">@${userName}</span>에게 답글 작성 중...
      </span>
      <button onclick="cancelReply()" class="text-slate-400 hover:text-slate-600">
        <%= icon "x", library: "tabler", class: "w-4 h-4" %>
      </button>
    `;
    
    const formContainer = messageInput.closest('.bg-slate-50');
    if (!document.getElementById('replyIndicator') && formContainer) {
      formContainer.parentNode.insertBefore(replyIndicator, formContainer);
    }
    
    // Scroll to input
    messageInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
}

function cancelReply() {
  // Find the message input field (could be input or textarea)
  const messageInput = document.querySelector('textarea[name="message[body]"]') || document.querySelector('input[name="message[body]"]');
  const parentMessageIdField = document.getElementById('parent_message_id');
  
  if (messageInput) {
    delete messageInput.dataset.replyToId;
  }
  
  if (parentMessageIdField) {
    parentMessageIdField.value = '';
  }
  
  const indicator = document.getElementById('replyIndicator');
  if (indicator) {
    indicator.remove();
  }
}

async function toggleSave(messageId) {
