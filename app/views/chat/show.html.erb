function goToChannelStep2() {
  const checkboxes = document.querySelectorAll('#membersList input[type="checkbox"]:checked');
  
  // Get selected member names
  const selectedNames = Array.from(checkboxes).map(cb => cb.closest('label').dataset.userName);
  
  // Include current user
  const currentUserName = '<%= current_user.name %>';
  const allNames = [currentUserName, ...selectedNames];
  
  // Generate channel name
