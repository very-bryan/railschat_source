async function deleteMessage() {
  if (!currentMessageId) return;
  
  if (confirm("정말로 이 메시지를 삭제하시겠습니까?")) {
    try {
      const channelId = <%= @current_channel.id %>;
      const response = await fetch(`/channels/${channelId}/messages/${currentMessageId}`, {
        method: "DELETE",
        headers: {
          "X-CSRF-Token": document.querySelector("[name='csrf-token']").content,
          "Accept": "text/vnd.turbo-stream.html"
        }
      });
      
      if (response.ok) {
        try {
          // Process the turbo stream response
          const text = await response.text();
          if (text && text.trim()) {
            console.log('[Delete] Turbo Stream response:', text);
            
            // Process the Turbo Stream manually
            const temp = document.createElement('div');
            temp.innerHTML = text;
            
            const turboStreamElements = temp.querySelectorAll('turbo-stream');
            turboStreamElements.forEach(streamElement => {
              const action = streamElement.getAttribute('action');
              const target = streamElement.getAttribute('target');
              
              if (action === 'remove') {
                const targetElement = document.getElementById(target);
                if (targetElement) {
                  targetElement.remove();
                }
              } else if (action === 'replace') {
                const targetElement = document.getElementById(target);
                if (targetElement) {
                  const template = streamElement.querySelector('template');
                  if (template) {
                    targetElement.outerHTML = template.innerHTML;
                  }
                }
              }
            });
          }
          showToast("메시지가 삭제되었습니다");
        } catch (e) {
          // If Turbo stream fails, manually remove the element
          const messageEl = document.getElementById(`message-${currentMessageId}`);
          if (messageEl) {
            messageEl.remove();
          }
          showToast("메시지가 삭제되었습니다");
        }
      } else {
        showToast("메시지 삭제에 실패했습니다");
      }
    } catch (error) {
      console.error("Error deleting message:", error);
      showToast("메시지 삭제 중 오류가 발생했습니다");
    }
  }
  
  document.getElementById('moreMenu').classList.add('hidden');
}

function showToast(message) {
  const toast = document.createElement("div");
  toast.className = "fixed bottom-4 right-4 bg-slate-900 text-white px-4 py-2 rounded-lg shadow-lg z-50";
  toast.textContent = message;
  document.body.appendChild(toast);
  
  setTimeout(() => {
    toast.remove();
  }, 3000);
}

function editMessage(messageId) {
  const messageEl = document.getElementById(`message-${messageId}`);
  const messageContent = document.getElementById(`message-content-${messageId}`);
  
  if (!messageContent) return;
  
  // Add editing class to hide action buttons
  messageEl.classList.add('editing');
  
  // Get the original message body from data attribute or extract from HTML
  const messageData = messageEl.dataset.messageBody;
  let cleanText = '';
  
  if (messageData) {
    cleanText = messageData;
  } else {
    // Extract text and convert <br> back to newlines
    const htmlContent = messageContent.innerHTML;
    cleanText = htmlContent
      .replace(/<br>/g, '\n')
      .replace(/<[^>]*>/g, '') // Remove all other HTML tags
      .trim();
    
    // Remove reply mention if it exists
    const replyMatch = cleanText.match(/^↩️\s*@\w+\s*/);
    if (replyMatch) {
      cleanText = cleanText.substring(replyMatch[0].length);
    }
  }
  
  // Create edit form - always use textarea for consistency
  const editForm = document.createElement('form');
  editForm.className = 'flex gap-2 items-end';
  
  // Always use textarea to support Shift+Enter
  const escapedText = cleanText.replace(/</g, '&lt;').replace(/>/g, '&gt;');
  
  // Calculate initial rows based on line breaks
  const lineCount = cleanText.split('\n').length;
  const initialRows = lineCount === 1 ? 1 : Math.min(lineCount, 10);
  
  editForm.innerHTML = `
    <textarea class="flex-1 px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-slate-400 focus:border-slate-400 resize-none overflow-hidden" 
              style="line-height: 1.5;" 
              rows="${initialRows}">${escapedText}</textarea>
    <button type="submit" class="px-3 py-1.5 bg-[#FF6D75] text-white text-sm rounded-md hover:bg-[#E85560]">저장</button>
    <button type="button" onclick="cancelEdit('${messageId}')" class="px-3 py-1.5 bg-slate-200 text-slate-700 text-sm rounded-md hover:bg-slate-300">취소</button>
  `;
  
  // Hide all content and replace with form
  const messageContainer = messageContent.parentNode;
  
  // Hide original message
  messageContent.style.display = 'none';
  
  // Hide any existing YouTube/link previews, reactions, thread previews
  const previews = messageContainer.querySelectorAll('.youtube-preview, .link-preview, .mt-2, .mt-3');
  previews.forEach(el => el.style.display = 'none');
  
  // Insert edit form
  messageContainer.insertBefore(editForm, messageContent.nextSibling);
  
  // Focus on textarea
  const textarea = editForm.querySelector('textarea');
  
  // Auto-resize function
  function autoResize() {
    textarea.style.height = 'auto';
    textarea.style.height = textarea.scrollHeight + 'px';
  }
  
  // Initial resize to fit content
  setTimeout(() => {
    autoResize();
  }, 0);
  
  // Add input event listener for auto-resize
  textarea.addEventListener('input', autoResize);
  
  textarea.focus();
  textarea.setSelectionRange(textarea.value.length, textarea.value.length);
  
  // Add keyboard event handlers
  textarea.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      if (e.shiftKey) {
        // Shift+Enter: allow new line - just let it happen naturally
        return;
      } else {
        // Enter without Shift: submit form
        e.preventDefault();
        editForm.dispatchEvent(new Event('submit'));
      }
    } else if (e.key === 'Escape') {
      // Escape: cancel edit
      e.preventDefault();
      cancelEdit(messageId);
    }
  });
  
  // Handle form submission
  editForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const newBody = textarea.value.trim();
    
    if (!newBody) {
      showToast('메시지를 입력해주세요');
      return;
    }
    
    try {
      const response = await fetch(`/messages/${messageId}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
          'Accept': 'text/vnd.turbo-stream.html'
        },
        body: JSON.stringify({ message: { body: newBody } })
      });
      
      if (!response.ok) throw new Error('Failed to update message');
      
      // Process Turbo Stream response
      const text = await response.text();
      console.log('[Edit] Turbo Stream response:', text);
      
      if (text && text.trim()) {
        // Create a temporary element to hold the response
        const temp = document.createElement('div');
        temp.innerHTML = text;
        
        // Execute Turbo Stream actions manually
        const turboStreamElements = temp.querySelectorAll('turbo-stream');
        turboStreamElements.forEach(streamElement => {
          const action = streamElement.getAttribute('action');
          const target = streamElement.getAttribute('target');
          
          if (action === 'replace') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              const template = streamElement.querySelector('template');
              if (template) {
                targetElement.outerHTML = template.innerHTML;
              }
            }
          }
        });
      }
      
      showToast('메시지가 수정되었습니다');
    } catch (error) {
      console.error('Error:', error);
      showToast('수정 중 오류가 발생했습니다');
      cancelEdit(messageId);
    }
  });
  
  // Handle keyboard shortcuts
  inputElement.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      cancelEdit(messageId);
    } else if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      editForm.dispatchEvent(new Event('submit'));
    }
  });
}

function cancelEdit(messageId) {
  const messageEl = document.getElementById(`message-${messageId}`);
  const messageContent = document.getElementById(`message-content-${messageId}`);
  const editForm = messageEl.querySelector('form');
  
  // Remove editing class to show action buttons again
  messageEl.classList.remove('editing');
  
  if (editForm) {
    editForm.remove();
  }
  
  if (messageContent) {
    messageContent.style.display = '';
  }
}

// Toggle thread replies visibility
function toggleThreadReplies(messageId) {
  const repliesContainer = document.getElementById(`thread-replies-${messageId}`);
  const chevron = document.getElementById(`thread-chevron-${messageId}`);
  
  if (repliesContainer) {
    if (repliesContainer.classList.contains('hidden')) {
