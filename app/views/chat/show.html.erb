function filterChannels(searchTerm) {
  console.log('Filtering channels with term:', searchTerm);
  const channelItems = document.querySelectorAll('.channel-item');
  const term = searchTerm.toLowerCase().trim();
  let visibleCount = 0;
  
  channelItems.forEach(item => {
    const channelName = item.dataset.channelName || '';
    console.log('Checking channel:', channelName, 'against term:', term);
    
    if (term === '' || channelName.includes(term)) {
      item.style.display = 'flex';
      visibleCount++;
    } else {
      item.style.display = 'none';
    }
  });
  
  console.log('Visible channels:', visibleCount);
  
  // Handle empty state
  const channelsList = document.getElementById('channelsList');
  let emptyState = document.querySelector('.channel-empty-state');
  
  if (visibleCount === 0 && term !== '') {
    if (!emptyState) {
      // Save original content
      if (!channelsList.dataset.originalContent) {
        channelsList.dataset.originalContent = channelsList.innerHTML;
      }
      channelsList.innerHTML += '<p class="channel-empty-state text-sm text-slate-500 text-center py-4">검색 결과가 없습니다</p>';
    }
  } else if (emptyState) {
    emptyState.remove();
  }
  
  // Restore original content when search is cleared
  if (term === '' && channelsList.dataset.originalContent) {
    channelsList.innerHTML = channelsList.dataset.originalContent;
    delete channelsList.dataset.originalContent;
    // Re-run filter to show all
    document.querySelectorAll('.channel-item').forEach(item => {
      item.style.display = 'flex';
    });
  }
}

async function toggleFavorite(channelId) {
  const button = event.currentTarget;
  const icon = button.querySelector('svg');
  
  console.log('Toggling favorite for channel:', channelId);
  console.log('Current favorited state:', button.dataset.favorited);
  console.log('CSRF Token:', document.querySelector('[name="csrf-token"]').content);
  
  try {
    const response = await fetch(`/channels/${channelId}/toggle_favorite`, {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
        'Accept': 'application/json',
        'Content-Type': 'application/json'
      },
      credentials: 'same-origin'
    });
    
    if (!response.ok) {
      console.error('Response not OK. Status:', response.status);
      let errorMessage = `HTTP error! status: ${response.status}`;
      try {
        const errorData = await response.json();
        console.error('Error response data:', errorData);
        errorMessage = errorData.error || errorMessage;
      } catch (e) {
        console.error('Could not parse error response as JSON:', e);
      }
      throw new Error(errorMessage);
    }
    
    const data = await response.json();
    console.log('JSON response:', data);
    
    if (data.status === 'ok') {
      button.dataset.favorited = data.is_favorited;
      
      if (data.is_favorited) {
        button.style.color = '#FF6D75';
        icon.classList.add('fill-current');
      } else {
        button.style.color = '#94a3b8';
        icon.classList.remove('fill-current');
      }
      
      // Simple reload to update sidebar
      // This is temporary - we can improve this later
      setTimeout(() => {
        window.location.reload();
      }, 100);
    }
  } catch (error) {
    console.error('Error toggling favorite:', error);
    showToast('즐겨찾기 변경에 실패했습니다');
  }
}
