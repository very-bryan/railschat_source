// Mention autocomplete functionality
let mentionDropdown = null;
let mentionQuery = '';
let mentionStartIndex = -1;
let selectedMentionIndex = 0;
let mentionUsers = [];

function handleMessageInput(event, textarea) {
  const cursorPosition = textarea.selectionStart;
  const textBeforeCursor = textarea.value.substring(0, cursorPosition);
  const lastAtIndex = textBeforeCursor.lastIndexOf('@');
  
  if (lastAtIndex !== -1 && lastAtIndex === textBeforeCursor.length - 1) {
    // Just typed @
    mentionStartIndex = lastAtIndex;
    mentionQuery = '';
    showMentionDropdown(textarea);
    searchMentionUsers('');
  } else if (lastAtIndex !== -1 && mentionStartIndex !== -1) {
    // Check if we're still in a mention
    const textAfterAt = textBeforeCursor.substring(lastAtIndex + 1);
    const hasSpace = textAfterAt.includes(' ');
    
    // Updated regex to support Korean characters
    const mentionPattern = /^[가-힣a-zA-Z0-9_]+$/;
    
    if (!hasSpace && textAfterAt.length > 0 && mentionPattern.test(textAfterAt)) {
      mentionQuery = textAfterAt;
      searchMentionUsers(mentionQuery);
    } else {
      hideMentionDropdown();
    }
  } else {
    hideMentionDropdown();
  }
  
  // Also call the original height adjustment function
  adjustTextareaHeight(textarea);
}

async function searchMentionUsers(query) {
  const channelId = document.getElementById('message_body').dataset.channelId;
  
  try {
    const response = await fetch(`/channels/${channelId}/mentionable_users?query=${encodeURIComponent(query)}`, {
      headers: {
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      }
    });
    
    if (response.ok) {
      const data = await response.json();
      mentionUsers = data.users;
      renderMentionDropdown(mentionUsers);
    }
  } catch (error) {
    console.error('Error searching users:', error);
  }
}

function renderMentionDropdown(users) {
  const dropdown = document.getElementById('mentionDropdown');
  const content = document.getElementById('mentionDropdownContent');
  
  if (users.length === 0) {
    hideMentionDropdown();
    return;
  }
  
  content.innerHTML = users.map((user, index) => `
    <button type="button"
            class="w-full px-3 py-2 flex items-center gap-2 hover:bg-slate-100 ${index === selectedMentionIndex ? 'bg-slate-100' : ''}"
            onclick="selectMention('${user.name}', ${user.id})"
            data-mention-index="${index}">
      ${user.avatar_url ? 
        `<img src="${user.avatar_url}" alt="${user.name}" class="w-6 h-6 rounded-full">` :
        `<div class="w-6 h-6 rounded-full bg-[#FF6D75] flex items-center justify-center text-white text-xs font-medium">
          ${user.name.charAt(0).toUpperCase()}
        </div>`
      }
      <span class="text-sm text-slate-900">${user.name}</span>
    </button>
  `).join('');
  
  dropdown.classList.remove('hidden');
}

function showMentionDropdown(textarea) {
  const dropdown = document.getElementById('mentionDropdown');
  mentionDropdown = dropdown;
  selectedMentionIndex = 0;
}

function hideMentionDropdown() {
  const dropdown = document.getElementById('mentionDropdown');
  dropdown.classList.add('hidden');
  mentionStartIndex = -1;
  mentionQuery = '';
  selectedMentionIndex = 0;
  mentionUsers = [];
}

function selectMention(userName, userId) {
  const textarea = document.getElementById('message_body');
  const cursorPosition = textarea.selectionStart;
  const textBeforeMention = textarea.value.substring(0, mentionStartIndex);
  const textAfterCursor = textarea.value.substring(cursorPosition);
  
  textarea.value = textBeforeMention + '@' + userName + ' ' + textAfterCursor;
  
  // Set cursor position after the mention
  const newCursorPosition = mentionStartIndex + userName.length + 2;
  textarea.setSelectionRange(newCursorPosition, newCursorPosition);
  textarea.focus();
  
  hideMentionDropdown();
  adjustTextareaHeight(textarea);
}

// Handle message input keypress
function handleMessageKeyPress(event, textarea) {
  // Handle mention dropdown navigation
  if (!document.getElementById('mentionDropdown').classList.contains('hidden')) {
    if (event.key === 'ArrowDown') {
      event.preventDefault();
      selectedMentionIndex = Math.min(selectedMentionIndex + 1, mentionUsers.length - 1);
      renderMentionDropdown(mentionUsers);
      return;
    } else if (event.key === 'ArrowUp') {
      event.preventDefault();
      selectedMentionIndex = Math.max(selectedMentionIndex - 1, 0);
      renderMentionDropdown(mentionUsers);
      return;
    } else if (event.key === 'Enter' || event.key === 'Tab') {
      event.preventDefault();
      if (mentionUsers[selectedMentionIndex]) {
        selectMention(mentionUsers[selectedMentionIndex].name, mentionUsers[selectedMentionIndex].id);
      }
      return;
    } else if (event.key === 'Escape') {
      event.preventDefault();
      hideMentionDropdown();
      return;
    }
  }
  if (event.key === 'Enter' && !event.shiftKey) {
    event.preventDefault();
    
    // Prevent duplicate submissions
    if (isSubmitting) return;
    
    const form = textarea.closest('form');
    
    // Check if message is empty
    if (!textarea.value.trim()) return;
    
    // Send message asynchronously
    sendMessage(form, textarea);
  } else if (event.key === 'Escape') {
    // Cancel reply on Escape key
    cancelReply();
  }
}

// Send message asynchronously (like thread)
async function sendMessage(eventOrForm, textarea) {
  // Handle both event and form parameters
  let form;
  if (eventOrForm.preventDefault) {
    // It's an event
    eventOrForm.preventDefault();
    form = eventOrForm.target;
    textarea = form.querySelector('#message_body');
  } else {
    // It's a form element
    form = eventOrForm;
  }
  const body = textarea.value.trim();
  const noteId = document.getElementById('note_id')?.value;
  
  // Check if we have content (either text, files, or note)
  if (!body && selectedFiles.length === 0 && !noteId) return;
  
  // Set submitting flag
  isSubmitting = true;
  
  // Save current scroll position
  const messagesContainer = document.getElementById('messagesContainer');
  const scrollPosition = messagesContainer ? messagesContainer.scrollTop : 0;
  const parentMessageId = document.getElementById('parent_message_id')?.value;
  
  try {
    const channelId = <%= @current_channel.id %>;
    const csrfToken = document.querySelector("[name='csrf-token']").content;
    
    // Use FormData for file uploads
    const formData = new FormData();
    formData.append('message[body]', body);
    
    if (parentMessageId) {
      formData.append('message[parent_message_id]', parentMessageId);
    }
    
    if (noteId) {
      formData.append('message[note_id]', noteId);
    }
    
    // Add files
    selectedFiles.forEach(file => {
      formData.append('message[attachments][]', file);
    });
    
    const response = await fetch(`/channels/${channelId}/messages`, {
      method: 'POST',
      headers: {
        'X-CSRF-Token': csrfToken,
        'Accept': 'text/vnd.turbo-stream.html, application/json'
      },
      body: formData
    });
    
    if (response.ok) {
      console.log('[Chat] Response OK, clearing textarea and focusing');
      // Clear textarea immediately after successful send
      textarea.value = '';
      
      // Clear reply state
      cancelReply();
      
      // Clear files
      selectedFiles = [];
      document.getElementById('file-preview-container').innerHTML = '';
      document.getElementById('file-preview-area').classList.add('hidden');
      
      // Clear note
      removeNote();
      
      // Reset textarea height
      textarea.style.height = 'auto';
      adjustTextareaHeight(textarea);
      
      // Maintain focus
      setTimeout(() => {
        console.log('[Chat] Setting focus back to textarea');
        textarea.focus();
      }, 50);
      
      // Handle Turbo Stream response
      const contentType = response.headers.get('content-type');
      if (contentType && contentType.includes('text/vnd.turbo-stream.html')) {
        const text = await response.text();
        // Process Turbo Stream manually
        const temp = document.createElement('div');
        temp.innerHTML = text;
        
        const turboStreamElements = temp.querySelectorAll('turbo-stream');
        turboStreamElements.forEach(streamElement => {
          const action = streamElement.getAttribute('action');
          const target = streamElement.getAttribute('target');
          
          // Skip form replacement to maintain focus
          if (action === 'replace' && target === 'new_message') {
            console.log('[Chat] Skipping form replacement to maintain focus');
            return;
          }
          
          if (action === 'append') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              const template = streamElement.querySelector('template');
              if (template) {
                targetElement.insertAdjacentHTML('beforeend', template.innerHTML);
              }
            }
          } else if (action === 'replace') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              const template = streamElement.querySelector('template');
              if (template) {
                targetElement.outerHTML = template.innerHTML;
              }
            }
          } else if (action === 'remove') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              targetElement.remove();
            }
          }
        });
      }
      
      // Scroll handling based on whether it's a reply or new message
      setTimeout(() => {
        const messagesContainer = document.getElementById('messagesContainer');
        if (messagesContainer) {
          if (parentMessageId) {
            // For replies, scroll to the parent message area
            const parentMessage = document.getElementById(`message-${parentMessageId}`);
            if (parentMessage) {
              // Find the thread replies container
              const threadReplies = document.getElementById(`thread-replies-${parentMessageId}`);
              if (threadReplies) {
                // Scroll to show the thread area
                const parentTop = parentMessage.offsetTop;
                const threadBottom = threadReplies.offsetTop + threadReplies.offsetHeight;
                const containerHeight = messagesContainer.offsetHeight;
                
                // Calculate optimal scroll position to show both parent and replies
                const scrollTo = Math.max(0, threadBottom - containerHeight + 100);
                messagesContainer.scrollTop = scrollTo;
              } else {
                // If no thread container yet, just scroll to parent
                parentMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            } else {
              // Fallback to saved position
              messagesContainer.scrollTop = scrollPosition;
            }
          } else {
            // For new messages, scroll to bottom
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
          }
        }
      }, 150);
    } else {
      console.error('Failed to send message');
      showToast('메시지 전송에 실패했습니다');
    }
  } catch (error) {
    console.error('Error sending message:', error);
    showToast('메시지 전송 중 오류가 발생했습니다');
  } finally {
    // Reset submitting flag
    setTimeout(() => {
      isSubmitting = false;
    }, 500);
  }
}

// Auto-adjust textarea height
function adjustTextareaHeight(textarea) {
  // Reset height to auto to get the correct scrollHeight
  textarea.style.height = 'auto';
  
  // Calculate new height
  const scrollHeight = textarea.scrollHeight;
  const minHeight = 24;
  const maxHeight = 120;
  
  // Set new height within bounds
  const newHeight = Math.min(Math.max(scrollHeight, minHeight), maxHeight);
  textarea.style.height = newHeight + 'px';
  
  // Add scrollbar if content exceeds max height
  if (scrollHeight > maxHeight) {
    textarea.style.overflowY = 'auto';
  } else {
    textarea.style.overflowY = 'hidden';
  }
}

