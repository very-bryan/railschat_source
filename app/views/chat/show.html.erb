// Auto-scroll to bottom of messages
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById('messagesContainer');
  if (container) {
    container.scrollTop = container.scrollHeight;
  }
  
  // Clean up any existing reply indicators on page load
  const replyIndicator = document.getElementById('replyIndicator');
  if (replyIndicator) {
    replyIndicator.remove();
  }
  
  const parentMessageIdField = document.getElementById('parent_message_id');
  if (parentMessageIdField) {
    parentMessageIdField.value = '';
  }
  
  const messageInput = document.querySelector('textarea[name="message[body]"]') || document.querySelector('input[name="message[body]"]');
  if (messageInput && messageInput.dataset.replyToId) {
    delete messageInput.dataset.replyToId;
  }
  
  // Add form submit handler to prevent duplicate submissions
  const messageForm = document.querySelector('form[action="/messages"]');
  if (messageForm) {
    messageForm.addEventListener('submit', function(e) {
      if (isSubmitting) {
        e.preventDefault();
        return false;
      }
      const textarea = this.querySelector('input[name="message[body]"]') || this.querySelector('textarea[name="message[body]"]');
      if (!textarea || !textarea.value.trim()) {
        e.preventDefault();
        return false;
      }
      isSubmitting = true;
      setTimeout(() => {
        isSubmitting = false;
      }, 1000);
    });
  }
});

