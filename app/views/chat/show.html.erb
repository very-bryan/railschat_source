async function togglePinMessage(messageId) {
  try {
    const response = await fetch(`/messages/${messageId}/pin`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-CSRF-Token": document.querySelector("[name='csrf-token']").content,
        "Accept": "text/vnd.turbo-stream.html"
      }
    });
    
    if (response.ok) {
      // Process Turbo Stream response
      const text = await response.text();
      if (text && text.trim()) {
        // Create a temporary element to hold the response
        const temp = document.createElement('div');
        temp.innerHTML = text;
        
        // Execute Turbo Stream actions manually
        const turboStreamElements = temp.querySelectorAll('turbo-stream');
        turboStreamElements.forEach(streamElement => {
          const action = streamElement.getAttribute('action');
          const target = streamElement.getAttribute('target');
          
          if (action === 'replace') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              const template = streamElement.querySelector('template');
              if (template) {
                targetElement.outerHTML = template.innerHTML;
              }
            }
          } else if (action === 'update') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              const template = streamElement.querySelector('template');
              if (template) {
                targetElement.innerHTML = template.innerHTML;
              }
            }
          }
        });
        
        // Update pinned messages bar if needed
        const pinnedBar = document.getElementById('pinnedMessagesBar');
        if (pinnedBar) {
          window.location.reload();
        }
      }
      showToast("메시지 고정 상태가 변경되었습니다");
    } else {
      throw new Error('Failed to toggle pin');
    }
  } catch (error) {
    console.error("Error pinning message:", error);
    showToast("고정 중 오류가 발생했습니다");
  }
}

async function pinMessage() {
  if (!currentMessageId) return;
  document.getElementById('moreMenu').classList.add('hidden');
  await togglePinMessage(currentMessageId);
}

function copyMessage(messageId) {
  const messageContent = document.getElementById(`message-content-${messageId}`);
  if (!messageContent) {
    showToast('메시지를 찾을 수 없습니다');
    return;
  }
  
  const text = messageContent.textContent || messageContent.innerText;
  
  navigator.clipboard.writeText(text).then(() => {
    showToast('메시지가 클립보드에 복사되었습니다');
  }).catch(err => {
    console.error('복사 실패:', err);
    showToast('복사에 실패했습니다');
  });
}

