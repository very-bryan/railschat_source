function handleFileSelection(event) {
  const files = Array.from(event.target.files);
  if (files.length === 0) return;
  
  // Allowed file extensions
  const allowedExtensions = ['jpg', 'jpeg', 'png', 'gif', 'webp', 'mp4', 'mpeg', 'mov', 'qt', 'avi', 'wmv', 'webm', 'pdf', 'doc', 'docx', 'xls', 'xlsx', 'ppt', 'pptx', 'txt', 'zip', 'rar'];
  
  files.forEach(file => {
    // Check file size (10MB for general files, 50MB for videos)
    const isVideo = ['mp4', 'mpeg', 'mov', 'qt', 'avi', 'wmv', 'webm'].includes(file.name.split('.').pop().toLowerCase());
    const maxSize = isVideo ? 50 * 1024 * 1024 : 25 * 1024 * 1024;
    const maxSizeMB = isVideo ? 50 : 25;
    
    if (file.size > maxSize) {
      showToast(`파일 "${file.name}"이 너무 큽니다. ${maxSizeMB}MB 이하만 가능합니다.`);
      return;
    }
    
    // Check file extension
    const extension = file.name.split('.').pop().toLowerCase();
    if (!allowedExtensions.includes(extension)) {
      showToast(`파일 "${file.name}"은 허용되지 않는 형식입니다.`);
      return;
    }
    
    selectedFiles.push(file);
    addFilePreview(file);
  });
  
  // Clear the input
  event.target.value = '';
  
  // Show preview area
  if (selectedFiles.length > 0) {
    document.getElementById('file-preview-area').classList.remove('hidden');
  }
}

function addFilePreview(file) {
  const container = document.getElementById('file-preview-container');
  const preview = document.createElement('div');
  preview.className = 'relative group';
  preview.dataset.fileName = file.name;
  
  const isImage = file.type.startsWith('image/');
  const isVideo = file.type.startsWith('video/');
  
  if (isImage) {
    // Image preview
    const reader = new FileReader();
    reader.onload = function(e) {
      preview.innerHTML = `
        <div class="relative w-20 h-20 rounded-lg overflow-hidden border border-slate-200">
          <img src="${e.target.result}" alt="${file.name}" class="w-full h-full object-cover">
          <button type="button" onclick="removeFile('${file.name}')" 
                  class="absolute top-0 right-0 p-1 bg-red-500 text-white rounded-bl opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      `;
    };
    reader.readAsDataURL(file);
  } else if (isVideo) {
    // Video preview
    const reader = new FileReader();
    reader.onload = function(e) {
      preview.innerHTML = `
        <div class="relative w-20 h-20 rounded-lg overflow-hidden border border-slate-200 bg-slate-900">
          <video src="${e.target.result}" class="w-full h-full object-cover">
          </video>
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="bg-white bg-opacity-90 rounded-full p-2">
              <svg class="w-6 h-6 text-slate-700" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
          <button type="button" onclick="removeFile('${file.name}')" 
                  class="absolute top-0 right-0 p-1 bg-red-500 text-white rounded-bl opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      `;
    };
    reader.readAsDataURL(file);
  } else {
    // File preview with icon
    const extension = file.name.split('.').pop().toLowerCase();
    const icon = getFileIcon(extension);
    
    preview.innerHTML = `
      <div class="relative flex items-center gap-2 px-3 py-2 bg-white border border-slate-200 rounded-lg">
        <span class="text-2xl">${icon}</span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-slate-700 truncate">${file.name}</p>
          <p class="text-xs text-slate-500">${formatFileSize(file.size)}</p>
        </div>
        <button type="button" onclick="removeFile('${file.name}')" 
                class="p-1 text-red-500 opacity-0 group-hover:opacity-100 transition-opacity">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    `;
  }
  
  container.appendChild(preview);
}

function removeFile(fileName) {
  selectedFiles = selectedFiles.filter(f => f.name !== fileName);
  
  // Remove preview
  const preview = document.querySelector(`[data-file-name="${fileName}"]`);
  if (preview) preview.remove();
  
  // Hide preview area if no files
  if (selectedFiles.length === 0) {
    document.getElementById('file-preview-area').classList.add('hidden');
  }
}

function getFileIcon(extension) {
  const icons = {
    pdf: '📄',
    doc: '📝', docx: '📝',
    xls: '📊', xlsx: '📊',
    ppt: '📊', pptx: '📊',
    zip: '🗜️', rar: '🗜️',
    txt: '📃',
    default: '📎'
  };
  return icons[extension] || icons.default;
}

function formatFileSize(bytes) {
  if (bytes === 0) return '0 Bytes';
  const k = 1024;
  const sizes = ['Bytes', 'KB', 'MB', 'GB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

