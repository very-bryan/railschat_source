// Thread functions
let currentThreadMessageId = null;

async function showThread(messageId) {
  currentThreadMessageId = messageId;
  const panel = document.getElementById('threadPanel');
  
  try {
    // Load the original message and thread
    const response = await fetch(`/messages/${messageId}/thread`);
    if (response.ok) {
      const data = await response.json();
      
      // Display original message
      const originalContainer = document.getElementById('threadOriginalMessage');
      originalContainer.innerHTML = formatThreadMessage(data.original_message);
      
      // Display thread replies with grouping
      const threadContainer = document.getElementById('threadMessages');
      threadContainer.innerHTML = data.thread_messages.map((msg, index, array) => {
        const previousMsg = index > 0 ? array[index - 1] : null;
        return formatThreadMessage(msg, previousMsg);
      }).join('');
      
      // Show panel
      panel.classList.remove('hidden');
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }
  } catch (error) {
    console.error("Error loading thread:", error);
    // Fallback: just show the panel with a loading state
    panel.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
}

function formatThreadMessage(message, previousMessage = null) {
  const time = new Date(message.created_at).toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit' });
  const isSameUser = previousMessage && previousMessage.user_name === message.user_name;
  
  // Calculate time difference if same user
  let timeDiff = 0;
  if (isSameUser && previousMessage) {
    const prevTime = new Date(previousMessage.created_at);
    const currTime = new Date(message.created_at);
    timeDiff = (currTime - prevTime) / 1000 / 60; // difference in minutes
  }
  
  // Show full message if different user or more than 5 minutes gap
  if (!isSameUser || timeDiff > 5) {
    return `
      <div class="flex gap-3 px-2 py-1.5 hover:bg-slate-50 rounded thread-message" data-user-name="${message.user_name}" data-created-at="${message.created_at}">
        <div class="flex-shrink-0">
          ${message.user_avatar_url ? 
            `<img src="${message.user_avatar_url}" alt="${message.user_name}" class="w-8 h-8 rounded-full">` :
            `<div class="w-8 h-8 bg-gradient-to-br from-[#FF6D75] to-[#E85560] rounded-full flex items-center justify-center">
              <span class="text-white text-xs font-medium">${message.user_name.charAt(0).toUpperCase()}</span>
            </div>`
          }
        </div>
        <div class="flex-1">
          <div class="flex items-baseline gap-2 mb-0.5">
            <span class="text-sm font-semibold text-slate-900">${message.user_name}</span>
            <span class="text-xs text-slate-500">${time}</span>
          </div>
          <p class="text-sm text-slate-700">${message.body_html || message.body}</p>
        </div>
      </div>
    `;
  } else {
    // Grouped message - only show message body and time on hover
    return `
      <div class="flex gap-3 px-2 py-0.5 hover:bg-slate-50 rounded group thread-message" data-user-name="${message.user_name}" data-created-at="${message.created_at}">
        <div class="flex-shrink-0 w-8"></div>
        <div class="flex-1">
          <div class="flex items-start gap-2">
            <p class="text-sm text-slate-700 flex-1">${message.body_html || message.body}</p>
            <span class="text-xs text-slate-500 opacity-0 group-hover:opacity-100 transition-opacity">${time}</span>
          </div>
        </div>
      </div>
    `;
  }
}

function closeThread() {
  document.getElementById('threadPanel').classList.add('hidden');
  document.body.style.overflow = 'auto';
  currentThreadMessageId = null;
}

// Helper function to get the last message in thread
function getLastThreadMessage() {
  const threadContainer = document.getElementById('threadMessages');
  const messages = threadContainer.querySelectorAll('.thread-message');
  if (messages.length === 0) return null;
  
  const lastMessage = messages[messages.length - 1];
  return {
    user_name: lastMessage.dataset.userName,
    created_at: lastMessage.dataset.createdAt
  };
}

// Add a new message to thread with grouping
function addThreadMessage(message) {
  const threadContainer = document.getElementById('threadMessages');
  const lastMessage = getLastThreadMessage();
  const messageHtml = formatThreadMessage(message, lastMessage);
  threadContainer.insertAdjacentHTML('beforeend', messageHtml);
}

let isThreadSubmitting = false;

function handleThreadKeyPress(event) {
  if (event.key === 'Enter' && !event.shiftKey) {
    event.preventDefault();
    
    // Prevent duplicate submissions
    if (isThreadSubmitting) return;
    
    const textarea = event.target;
    if (!textarea.value.trim()) return;
    
    sendThreadReply(event);
  }
}

async function sendThreadReply(event) {
  event.preventDefault();
  console.log('Sending thread reply, currentThreadMessageId:', currentThreadMessageId);
  
  // Prevent duplicate submissions
  if (isThreadSubmitting) {
    console.log('Already submitting thread reply');
    return;
  }
  
  if (!currentThreadMessageId) {
    console.error('No thread message ID set');
    return;
  }
  
  const form = event.target.closest('form') || event.target;
  const textarea = form.querySelector('textarea[name="reply_body"]');
  const body = textarea.value.trim();
  
  console.log('Reply body:', body);
  
  if (!body) {
    console.log('Empty reply body');
    return;
  }
  
  // Set submitting flag
  isThreadSubmitting = true;
  
  try {
    const channelId = <%= @current_channel.id %>;
    const csrfToken = document.querySelector("[name='csrf-token']").content;
    const requestBody = { 
      message: { 
        body: body, 
        parent_message_id: currentThreadMessageId 
      } 
    };
    
    console.log('Channel ID:', channelId);
    console.log('CSRF Token:', csrfToken);
    console.log('Request body:', requestBody);
    console.log('Request URL:', `/channels/${channelId}/messages`);
    
    const response = await fetch(`/channels/${channelId}/messages`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken,
        'Accept': 'text/vnd.turbo-stream.html, application/json'
      },
      body: JSON.stringify(requestBody)
    });
    
    console.log('Response status:', response.status);
    
    if (response.ok) {
      textarea.value = '';
      // Handle Turbo Stream response
      const contentType = response.headers.get('content-type');
      if (contentType && contentType.includes('text/vnd.turbo-stream.html')) {
        const text = await response.text();
        console.log('[Thread Reply] Turbo Stream response:', text);
        
        // Process the Turbo Stream manually instead of using renderStreamMessage
        const temp = document.createElement('div');
        temp.innerHTML = text;
        
        const turboStreamElements = temp.querySelectorAll('turbo-stream');
        turboStreamElements.forEach(streamElement => {
          const action = streamElement.getAttribute('action');
          const target = streamElement.getAttribute('target');
          
          // Skip form replacement to maintain focus
          if (action === 'replace' && target === 'new_message') {
            console.log('[Chat] Skipping form replacement to maintain focus');
            return;
          }
          
          if (action === 'append') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              const template = streamElement.querySelector('template');
              if (template) {
                targetElement.insertAdjacentHTML('beforeend', template.innerHTML);
              }
            }
          } else if (action === 'replace') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              const template = streamElement.querySelector('template');
              if (template) {
                targetElement.outerHTML = template.innerHTML;
              }
            }
          } else if (action === 'remove') {
            const targetElement = document.getElementById(target);
            if (targetElement) {
              targetElement.remove();
            }
          }
        });
      }
      
      // Reload thread to show new message
      setTimeout(() => {
        showThread(currentThreadMessageId);
      }, 200);
      
      // Don't reload the entire page to maintain state
      // Just update the thread reply count
      const messageEl = document.getElementById(`message-${currentThreadMessageId}`);
      if (messageEl) {
        const replyCountEl = messageEl.querySelector('.text-purple-600');
        if (replyCountEl) {
          const currentCount = parseInt(replyCountEl.textContent.match(/\d+/)?.[0] || '0');
          replyCountEl.textContent = `${currentCount + 1}개의 답글`;
        }
      }
    } else {
      console.error('Failed to send reply, status:', response.status);
      let errorMessage = '답글 전송에 실패했습니다';
      try {
        const errorText = await response.text();
        console.error('Error response:', errorText);
        const errorJson = JSON.parse(errorText);
        if (errorJson.errors && errorJson.errors.length > 0) {
          errorMessage = errorJson.errors.join(', ');
        }
      } catch (e) {
        // If not JSON, use default message
      }
      showToast(errorMessage);
    }
  } catch (error) {
    console.error("Error sending thread reply:", error);
    showToast('답글 전송 중 오류가 발생했습니다');
  } finally {
    // Reset submitting flag
    setTimeout(() => {
      isThreadSubmitting = false;
    }, 1000);
  }
}

// Image modal
function showImageModal(url, filename) {
  // Create modal if it doesn't exist
  let modal = document.getElementById('image-modal');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'image-modal';
    modal.className = 'fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-75';
    modal.onclick = function(e) {
      if (e.target === modal) closeImageModal();
    };
    
    modal.innerHTML = `
      <div class="relative max-w-7xl max-h-[90vh] mx-4">
        <button onclick="closeImageModal()" class="absolute -top-10 right-0 text-white hover:text-gray-300">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <img id="modal-image" src="" alt="" class="max-w-full max-h-[90vh] object-contain">
        <div id="modal-filename" class="absolute bottom-0 left-0 right-0 bg-black bg-opacity-50 text-white p-2 text-center text-sm"></div>
      </div>
    `;
    document.body.appendChild(modal);
  }
  
  // Set image and show modal
  document.getElementById('modal-image').src = url;
  document.getElementById('modal-filename').textContent = filename;
  modal.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  
  // Add ESC key listener
  document.addEventListener('keydown', handleImageModalEsc);
}

function handleImageModalEsc(e) {
  if (e.key === 'Escape') {
    closeImageModal();
  }
}

function closeImageModal() {
  const modal = document.getElementById('image-modal');
  if (modal) {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    // Remove ESC key listener
    document.removeEventListener('keydown', handleImageModalEsc);
  }
}

