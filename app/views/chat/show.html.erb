// Channel form functions
function toggleChannelForm() {
  const form = document.getElementById('channelForm');
  const content = document.getElementById('channelFormContent');
  const isHidden = form.classList.contains('hidden');
  
  if (isHidden) {
    // Show modal
    form.classList.remove('hidden');
    form.classList.add('opacity-0');
    
    // Trigger reflow
    form.offsetHeight;
    
    // Fade in
    form.classList.remove('opacity-0');
    
    // Scale up content
    setTimeout(() => {
      content.classList.remove('scale-95', 'opacity-0');
      content.classList.add('scale-100', 'opacity-100');
      
      // Focus on the first input
      const firstInput = form.querySelector('[data-modal-focus]');
      if (firstInput) firstInput.focus();
    }, 10);
    
    // Add ESC key listener
    document.addEventListener('keydown', handleModalEscape);
  } else {
    // Hide modal with animation
    content.classList.remove('scale-100', 'opacity-100');
    content.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
      form.classList.add('opacity-0');
      setTimeout(() => {
        form.classList.add('hidden');
        form.classList.remove('opacity-0');
        // Reset form
        const formElement = form.querySelector('form');
        if (formElement) formElement.reset();
        // Clear search
        const searchInput = form.querySelector('input[placeholder="이름으로 검색..."]');
        if (searchInput) {
          searchInput.value = '';
          filterChannelMembers('');
        }
        // Reset to step 1
        document.getElementById('channelFormStep2').classList.add('hidden');
        document.getElementById('channelFormStep1').classList.remove('hidden');
        // Clear selected members preview
        const preview = document.getElementById('selectedMembersPreview');
        if (preview) preview.innerHTML = '';
      }, 200);
    }, 200);
    
    document.removeEventListener('keydown', handleModalEscape);
  }
}

function handleModalEscape(e) {
  if (e.key === 'Escape') {
    toggleChannelForm();
  }
}

function filterChannelMembers(searchTerm) {
  const memberItems = document.querySelectorAll('.member-item');
  const term = searchTerm.toLowerCase();
  
  memberItems.forEach(item => {
    const name = item.dataset.name;
    if (name.includes(term)) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
}

// Members Management Modal
let currentChannelId = null;
let membersToAdd = new Set();
let membersToRemove = new Set();

async function toggleMembersModal(channelId = null) {
  const modal = document.getElementById('membersModal');
  const content = document.getElementById('membersModalContent');
  const isHidden = modal.classList.contains('hidden');
  
  if (isHidden && channelId) {
    currentChannelId = channelId;
    membersToAdd.clear();
    membersToRemove.clear();
    
    // Show modal with animation
    modal.classList.remove('hidden');
    modal.classList.add('opacity-0');
    modal.offsetHeight;
    modal.classList.remove('opacity-0');
    
    setTimeout(() => {
      content.classList.remove('scale-95', 'opacity-0');
      content.classList.add('scale-100', 'opacity-100');
    }, 10);
    
    // Load channel members
    await loadChannelMembers(channelId);
    
    document.addEventListener('keydown', handleMembersModalEscape);
  } else {
    // Hide modal with animation
    content.classList.remove('scale-100', 'opacity-100');
    content.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
      modal.classList.add('opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('opacity-0');
        currentChannelId = null;
      }, 200);
    }, 200);
    
    document.removeEventListener('keydown', handleMembersModalEscape);
  }
}

function handleMembersModalEscape(e) {
  if (e.key === 'Escape') {
    toggleMembersModal();
  }
}

async function loadChannelMembers(channelId) {
  try {
    console.log('Loading members for channel:', channelId);
    const response = await fetch(`/channels/${channelId}/members`, {
      headers: {
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      }
    });
    
    if (!response.ok) {
      const errorText = await response.text();
      console.error('Failed to load members:', response.status, errorText);
      throw new Error('Failed to load members');
    }
    
    const data = await response.json();
    console.log('Loaded members data:', data);
    
    // Display current members
    const currentMembersList = document.getElementById('currentMembersList');
    currentMembersList.innerHTML = data.current_members.map(member => `
      <div class="flex items-center justify-between p-2 hover:bg-slate-50 rounded">
        <div class="flex items-center gap-3">
          ${member.avatar_url ? 
            `<img src="${member.avatar_url}" alt="${member.name}" class="w-8 h-8 rounded-full">` :
            `<div class="w-8 h-8 rounded-full bg-[#FF6D75] flex items-center justify-center text-white text-sm font-medium">
              ${member.name.charAt(0).toUpperCase()}
            </div>`
          }
          <div>
            <div class="flex items-center gap-2">
              <p class="text-sm font-medium text-slate-900">${member.name}</p>
              ${member.role === 'admin' ? 
                '<span class="px-1.5 py-0.5 text-xs font-medium bg-purple-100 text-purple-700 rounded">관리자</span>' : 
                ''
              }
            </div>
            <p class="text-xs text-slate-500">${member.email}</p>
          </div>
        </div>
        ${member.can_remove ? 
          `<button onclick="toggleRemoveMember('${member.id}', '${member.name}')" 
                   data-member-id="${member.id}"
                   class="text-sm text-red-600 hover:text-red-700 remove-member-btn">
            제거
          </button>` : 
          member.role === 'admin' ? 
            '<span class="text-xs text-slate-400">제거 불가</span>' :
            ''
        }
      </div>
    `).join('');
    
    // Display available members
    const availableMembersList = document.getElementById('availableMembersList');
    availableMembersList.innerHTML = data.available_members.map(member => `
      <label class="flex items-center p-2 hover:bg-slate-50 rounded cursor-pointer available-member-item" 
             data-name="${member.name.toLowerCase()}"
             data-member-id="${member.id}">
        <input type="checkbox" 
               value="${member.id}" 
               onchange="toggleAddMember('${member.id}')"
               class="h-4 w-4 text-[#FF6D75] focus:ring-[#FF6D75] border-slate-300 rounded">
        <div class="ml-3">
          <p class="text-sm font-medium text-slate-900">${member.name}</p>
          <p class="text-xs text-slate-500">${member.email}</p>
        </div>
      </label>
    `).join('') || '<p class="text-sm text-slate-500 text-center py-4">모든 사용자가 이미 채널에 참여중입니다</p>';
    
  } catch (error) {
    console.error('Error loading members:', error);
    showToast('멤버 목록을 불러오는데 실패했습니다');
  }
}

function toggleAddMember(memberId) {
  const checkbox = document.querySelector(`input[value="${memberId}"]`);
  const memberItem = checkbox.closest('.available-member-item');
  
  if (checkbox.checked) {
    membersToAdd.add(memberId);
    
    // Extract member info
    const nameEl = memberItem.querySelector('.text-sm.font-medium');
    const emailEl = memberItem.querySelector('.text-xs.text-slate-500');
    const name = nameEl.textContent;
    const email = emailEl.textContent;
    
    // Move to current members list
    const currentMembersList = document.getElementById('currentMembersList');
    const newMemberHtml = `
      <div class="flex items-center justify-between p-2 hover:bg-slate-50 rounded opacity-60" id="pending-member-${memberId}">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-[#FF6D75] flex items-center justify-center text-white text-sm font-medium">
            ${name.charAt(0).toUpperCase()}
          </div>
          <div>
            <p class="text-sm font-medium text-slate-900">${name}</p>
            <p class="text-xs text-slate-500">${email}</p>
          </div>
        </div>
        <span class="text-xs text-green-600 font-medium">추가 예정</span>
      </div>
    `;
    currentMembersList.insertAdjacentHTML('beforeend', newMemberHtml);
    
    // Hide from available list
    memberItem.style.display = 'none';
  } else {
    membersToAdd.delete(memberId);
    
    // Remove from current members list
    const pendingMember = document.getElementById(`pending-member-${memberId}`);
    if (pendingMember) {
      pendingMember.remove();
    }
    
    // Show in available list again
    memberItem.style.display = 'flex';
  }
}

function toggleRemoveMember(memberId, memberName) {
  const button = document.querySelector(`button[data-member-id="${memberId}"]`);
  
  if (membersToRemove.has(memberId)) {
    membersToRemove.delete(memberId);
    button.textContent = '제거';
    button.classList.remove('line-through', 'opacity-50');
  } else {
    membersToRemove.add(memberId);
    button.textContent = '제거 예정';
    button.classList.add('line-through', 'opacity-50');
  }
}

function filterAvailableMembers(searchTerm) {
  const memberItems = document.querySelectorAll('.available-member-item');
  const term = searchTerm.toLowerCase();
  
  memberItems.forEach(item => {
    const name = item.dataset.name;
    if (name.includes(term)) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
}

async function saveChannelMembers() {
  if (membersToAdd.size === 0 && membersToRemove.size === 0) {
    showToast('변경사항이 없습니다');
    return;
  }
  
  try {
    console.log('Saving members - Add:', Array.from(membersToAdd), 'Remove:', Array.from(membersToRemove));
    
    const response = await fetch(`/channels/${currentChannelId}/update_members`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      },
      body: JSON.stringify({
        add_member_ids: Array.from(membersToAdd),
        remove_member_ids: Array.from(membersToRemove)
      })
    });
    
    const data = await response.json();
    console.log('Update response:', data);
    
    if (!response.ok) throw new Error('Failed to update members');
    
    showToast('멤버가 업데이트되었습니다');
    toggleMembersModal();
    
    // Reload page to update member count
    window.location.reload();
    
  } catch (error) {
    console.error('Error updating members:', error);
    showToast('멤버 업데이트에 실패했습니다');
  }
}

// 2-step channel creation functions
function updateSelectedMembers() {
