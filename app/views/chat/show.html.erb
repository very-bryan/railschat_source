    channelName = allNames.slice(0, 3).join(', ') + ', 외';
  }
  
  // Set the channel name field
  const channelNameField = document.getElementById('channel_name_field');
  if (channelNameField) {
    channelNameField.value = channelName;
  }
  
  // Switch to step 2
  document.getElementById('channelFormStep1').classList.add('hidden');
  document.getElementById('channelFormStep2').classList.remove('hidden');
  
  // Focus on channel name field
  setTimeout(() => {
    channelNameField.focus();
  }, 100);
}

function goToChannelStep1() {
