<% content_for :page_title, "실시간 채팅" %>

<!-- Main Container with Chat and Channel List -->
<div class="flex gap-4" style="height: calc(100vh - 6rem);">
  <!-- Chat Area -->
  <div class="flex-1 bg-white rounded-lg shadow-sm flex flex-col">
  <!-- Chat Header -->
  <div class="px-4 flex items-center border-b border-slate-200 bg-white rounded-t-lg" style="height: 54px;">
    <div class="flex items-center justify-between w-full">
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2">
          <span class="text-slate-500">#</span>
          <h2 class="text-lg font-semibold text-slate-900"><%= @current_channel.name %></h2>
        </div>
        <% if @current_channel.description.present? %>
          <span class="text-sm text-slate-500"><%= @current_channel.description %></span>
        <% end %>
      </div>
      <div class="flex items-center gap-3">
        <% if @current_channel.is_private? %>
          <%= icon "lock", library: "tabler", class: "w-4 h-4 text-slate-500" %>
        <% end %>
        <button onclick="toggleFavorite('<%= @current_channel.id %>')" 
                onmouseover="this.style.color='#FF6D75'"
                onmouseout="this.style.color=this.dataset.favorited === 'true' ? '#FF6D75' : '#94a3b8'"
                class="favorite-btn transition-colors"
                style="color: <%= @current_channel.favorited_by?(current_user) ? '#FF6D75' : '#94a3b8' %>;"
                data-favorited="<%= @current_channel.favorited_by?(current_user) %>">
          <%= icon "star", library: "tabler", class: "w-4 h-4 #{'fill-current' if @current_channel.favorited_by?(current_user)}" %>
        </button>
        <button onclick="toggleMembersModal('<%= @current_channel.id %>')" class="flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 transition-colors">
          <%= icon "users", library: "tabler", class: "w-4 h-4" %>
          <span><%= @current_channel.users.count %></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Pinned Messages Container -->
  <div id="pinnedMessagesContainer">
    <% if @pinned_messages.any? %>
      <div id="pinnedMessagesBar" class="bg-yellow-50 border-b border-yellow-200 px-4 py-2 cursor-pointer" onclick="cycleThroughPinnedMessages()">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 flex-1">
            <span class="text-yellow-700">📌</span>
            <div class="flex-1">
              <p class="text-sm font-medium text-yellow-800">고정된 메시지</p>
              <p id="pinnedMessagePreview" class="text-xs text-yellow-700 truncate">
                <%= @pinned_messages.first.body.truncate(50) %>
              </p>
            </div>
          </div>
          <button onclick="event.stopPropagation(); showAllPinnedMessages()" class="text-xs text-yellow-700 hover:text-yellow-800">
            모두 보기 (<%= @pinned_messages.count %>)
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Messages Area -->
  <div class="flex-1 overflow-y-auto p-4" id="messagesContainer" 
       data-controller="channel-reactions"
       data-channel-reactions-channel-id-value="<%= @current_channel.id %>"
       data-channel-id="<%= @current_channel.id %>">
    <% if @messages.any? %>
      <div class="space-y-1" id="messages-list">
        <% current_date = nil %>
        <% @messages.group_by { |m| m.created_at.to_date }.each do |date, messages| %>
        <% if current_date != date %>
          <div class="flex items-center gap-2 my-4">
            <div class="flex-1 h-px bg-slate-200"></div>
            <span class="text-xs text-slate-500 px-2">
              <%= date == Date.today ? "오늘" : date.strftime("%m월 %d일") %>
            </span>
            <div class="flex-1 h-px bg-slate-200"></div>
          </div>
          <% current_date = date %>
        <% end %>
        
        <% previous_message = nil %>
        <% messages.each do |message| %>
          <% if message.thread_root_id.nil? %>
            <div id="message-wrapper-<%= message.id %>">
              <%= render 'messages/message_grouped', message: message, previous_message: previous_message %>
              <% previous_message = message %>
              <!-- Thread replies container -->
              <div id="thread-replies-<%= message.id %>" class="thread-replies">
                <% if message.thread_messages.any? %>
                  <% thread_previous = nil %>
                  <% message.thread_messages.includes(:user, :reactions).each do |reply| %>
                    <div class="ml-12">
                      <%= render 'messages/message_grouped', message: reply, previous_message: thread_previous %>
                      <% thread_previous = reply %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
      </div>
    <% else %>
      <div class="flex items-center justify-center h-full text-slate-500">
        <div class="text-center">
          <%= icon "message-off", library: "tabler", class: "w-12 h-12 text-slate-300 mx-auto mb-2" %>
          <p class="text-sm">아직 메시지가 없습니다</p>
          <p class="text-xs text-slate-400">첫 메시지를 보내보세요!</p>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Message Input -->
  <div class="border-t border-slate-200 p-4">
    <%= render "messages/form", channel: @current_channel, message: @message %>
  </div>
  </div>
  
  <!-- Channel List Sidebar -->
  <div class="hidden lg:flex w-64 bg-white rounded-lg shadow-sm flex-col">
    <!-- Channel List Header -->
    <div class="px-4 flex items-center border-b border-slate-200" style="height: 54px;">
      <div class="flex items-center justify-between w-full">
        <h3 class="text-base font-semibold text-slate-900">채널</h3>
        <button onclick="toggleChannelForm()" class="text-slate-400 hover:text-slate-600 transition-colors">
          <%= icon "plus", library: "tabler", class: "w-5 h-5" %>
        </button>
      </div>
    </div>
    
    <!-- Channel Search -->
    <div class="p-2">
      <div class="relative">
        <input type="text" 
               placeholder="채널 검색..." 
               class="w-full pl-8 pr-3 py-1.5 text-sm border border-slate-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]"
               onkeyup="filterChannels(this.value)">
        <%= icon "search", library: "tabler", class: "absolute left-2.5 top-2 w-4 h-4 text-slate-400 pointer-events-none" %>
      </div>
    </div>
    
    <!-- Channel List -->
    <div class="flex-1 overflow-y-auto">
      <% if @channels && @channels.any? %>
        <div class="p-2" id="channelsList">
          <% @channels.each do |channel| %>
            <% is_current = @current_channel&.id == channel.id %>
            <a href="<%= chat_channel_path(channel) %>" 
               class="channel-item flex items-center gap-2 px-3 py-2 rounded-md transition-colors <%= is_current ? 'bg-[#FFF0F1] text-[#FF6D75]' : 'hover:bg-slate-50 text-slate-700' %>"
               data-channel-name="<%= channel.name.downcase %>"
               data-turbo-frame="_top">
              <span class="text-base <%= is_current ? 'text-[#FF6D75]' : 'text-slate-400' %>">#</span>
              <span class="flex-1 text-sm font-medium truncate"><%= channel.name %></span>
              <div class="flex items-center gap-1.5">
                <% if channel.is_private? %>
                  <%= icon "lock", library: "tabler", class: "w-3.5 h-3.5 #{is_current ? 'text-[#FF6D75]' : 'text-slate-400'}" %>
                <% end %>
                <span class="text-xs <%= is_current ? 'text-[#FF6D75]' : 'text-slate-400' %>">
                  <%= channel.users.count %>
                </span>
                <% unread_count = channel.unread_messages_count_for(current_user) %>
                <% if unread_count > 0 %>
                  <span class="px-1.5 py-0.5 text-xs font-medium bg-[#FF6D75] text-white rounded-full">
                    <%= unread_count > 99 ? '99+' : unread_count %>
                  </span>
                <% end %>
              </div>
            </a>
          <% end %>
        </div>
      <% else %>
        <div class="flex items-center justify-center h-full p-4">
          <div class="text-center">
            <p class="text-sm text-slate-500 mb-2">채널이 없습니다</p>
            <button onclick="toggleChannelForm()" class="text-sm text-[#FF6D75] hover:text-[#E85560]">
              첫 채널 만들기
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Members Management Modal -->
<div id="membersModal" class="fixed inset-0 hidden z-50 flex items-center justify-center transition-opacity duration-200" style="background-color: rgba(0, 0, 0, 0.2);" onclick="if(event.target === this) toggleMembersModal()">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-lg mx-4 transform transition-all duration-200 scale-95 opacity-0" id="membersModalContent">
    <div class="border-b border-slate-200 px-6 py-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-slate-900">채널 멤버 관리</h3>
        <button onclick="toggleMembersModal()" class="text-slate-400 hover:text-slate-600">
          <%= icon "x", library: "tabler", class: "w-5 h-5" %>
        </button>
      </div>
    </div>
    
    <div class="p-6">
      <!-- Current Members -->
      <div class="mb-6">
        <h4 class="text-sm font-medium text-slate-700 mb-3">현재 멤버</h4>
        <div class="space-y-2 max-h-60 overflow-y-auto" id="currentMembersList">
          <!-- Members will be loaded dynamically -->
        </div>
      </div>
      
      <!-- Add New Members -->
      <div>
        <h4 class="text-sm font-medium text-slate-700 mb-3">멤버 추가</h4>
        <div class="mb-3">
          <input type="text" 
                 placeholder="이름으로 검색..." 
                 class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]"
                 onkeyup="filterAvailableMembers(this.value)">
        </div>
        <div class="border border-slate-200 rounded-md max-h-40 overflow-y-auto">
          <div id="availableMembersList" class="p-2">
            <!-- Available members will be loaded dynamically -->
          </div>
        </div>
      </div>
      
      <!-- Action Buttons -->
      <div class="flex justify-end gap-2 pt-6 border-t border-slate-100 mt-6">
        <button type="button" 
                onclick="toggleMembersModal()" 
                class="px-4 py-2 border border-slate-200 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 transition-colors">
          닫기
        </button>
        <button type="button"
                onclick="saveChannelMembers()"
                class="px-4 py-2 bg-[#FF6D75] text-white rounded-md hover:bg-[#E85560] text-sm font-medium transition-colors">
          변경사항 저장
        </button>
      </div>
    </div>
  </div>
</div>

<!-- New Channel Form Modal -->
<div id="channelForm" class="fixed inset-0 hidden z-50 flex items-center justify-center transition-opacity duration-200" style="background-color: rgba(0, 0, 0, 0.2);" onclick="if(event.target === this) toggleChannelForm()">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 transform transition-all duration-200 scale-95 opacity-0" id="channelFormContent">
    <%= form_with model: Channel.new, url: channels_path, local: false, data: { turbo: true, turbo_frame: "_top" }, class: "", id: "new_channel_form" do |form| %>
      <!-- Step 1: Member Selection -->
      <div id="channelFormStep1" class="block">
        <div class="border-b border-slate-200 px-6 py-4">
          <h3 class="text-lg font-semibold text-slate-900">멤버 선택</h3>
          <p class="text-sm text-slate-500 mt-1">채널에 초대할 멤버를 선택하세요</p>
        </div>
        
        <div class="p-6">
          <div class="mb-4">
            <input type="text" 
                   placeholder="이름으로 검색..." 
                   class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]"
                   onkeyup="filterChannelMembers(this.value)">
          </div>
          
          <div class="border border-slate-200 rounded-md">
            <div class="max-h-80 overflow-y-auto p-2" id="membersList">
              <% all_users = current_user.current_workspace.users.where.not(id: current_user.id) %>
              <% if all_users.any? %>
                <% all_users.each do |user| %>
                  <label class="flex items-center p-3 hover:bg-slate-50 rounded cursor-pointer member-item" 
                         data-name="<%= user.name.downcase %>"
                         data-user-name="<%= user.name %>">
                    <%= check_box_tag "channel[member_ids][]", user.id, false, 
                        class: "h-4 w-4 text-[#FF6D75] focus:ring-[#FF6D75] border-slate-300 rounded",
                        onchange: "updateSelectedMembers()" %>
                    <span class="ml-3 text-sm text-slate-700"><%= user.name %></span>
                  </label>
                <% end %>
              <% else %>
                <p class="text-sm text-slate-500 text-center py-4">다른 사용자가 없습니다</p>
              <% end %>
            </div>
          </div>
          
          <div id="selectedMembersPreview" class="mt-4 text-sm text-slate-600"></div>
        </div>
        
        <div class="flex justify-end gap-2 px-6 pb-6">
          <button type="button" 
                  onclick="toggleChannelForm()" 
                  class="px-4 py-2 border border-slate-200 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 transition-colors">
            취소
          </button>
          <button type="button" 
                  onclick="goToChannelStep2()"
                  class="px-4 py-2 bg-[#FF6D75] text-white rounded-md hover:bg-[#E85560] text-sm font-medium transition-colors">
            다음
          </button>
        </div>
      </div>
      
      <!-- Step 2: Channel Details -->
      <div id="channelFormStep2" class="hidden">
        <div class="border-b border-slate-200 px-6 py-4">
          <h3 class="text-lg font-semibold text-slate-900">채널 정보</h3>
          <p class="text-sm text-slate-500 mt-1">채널명과 설명을 입력하세요</p>
        </div>
        
        <div class="p-6">
          <div id="channel_form_errors"></div>
          <div class="space-y-4">
            <div>
              <%= form.label :name, "채널명", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.text_field :name, 
                  class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]", 
                  placeholder: "채널명을 입력하세요",
                  required: true,
                  id: "channel_name_field" %>
              <p class="mt-1 text-xs text-slate-500">한글, 영문, 숫자, 쉼표, 공백 사용 가능</p>
            </div>
            
            <div>
              <%= form.label :description, "설명", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.text_area :description, 
                  rows: 3, 
                  class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75] resize-none", 
                  placeholder: "채널 설명을 입력하세요 (선택사항)" %>
            </div>

            <div class="flex items-center">
              <%= form.check_box :is_private, { checked: true, class: "h-4 w-4 text-[#FF6D75] focus:ring-[#FF6D75] border-slate-300 rounded", onchange: "togglePrivateDescription()" } %>
              <%= form.label :is_private, class: "ml-2 flex items-center gap-2 cursor-pointer" do %>
                <span class="text-sm text-slate-700">비공개 채널</span>
                <span id="privateChannelDescription" class="text-xs text-slate-500">(초대된 멤버만 접근 가능)</span>
              <% end %>
            </div>
          </div>
        </div>
        
        <div class="flex justify-between px-6 pb-6">
          <button type="button" 
                  onclick="goToChannelStep1()"
                  class="px-4 py-2 border border-slate-200 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 transition-colors">
            이전
          </button>
          <%= form.submit "채널 생성", 
              class: "px-4 py-2 bg-[#FF6D75] text-white rounded-md hover:bg-[#E85560] text-sm font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
              "data-disable-with": "생성 중..." %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Emoji Picker (Hidden by default) -->
<div id="emojiPicker" class="hidden fixed bg-white rounded-lg shadow-xl border border-slate-200 p-3 z-50" style="width: 280px;">
  <div class="text-sm font-medium text-slate-700 mb-2">이모지 선택</div>
  <div class="grid grid-cols-7 gap-1">
    <% %w[👍 🎉 🚀 👀 😂 ❤️ 🔥 🙏 👏 🙌 🤔 😅 🤝 💯 😎 📝 📈 📅 ⏰ 🔔 ✅ ❌ ⭕ ❗ ❓].each do |emoji| %>
      <button class="hover:bg-slate-100 rounded p-1 text-lg" onclick="selectEmoji('<%= emoji %>')">
        <%= emoji %>
      </button>
    <% end %>
  </div>
</div>

<!-- More Menu (Hidden by default) -->
<div id="moreMenu" class="hidden fixed bg-white rounded-lg shadow-xl border border-slate-200 p-1 z-50">
  <button class="w-full text-left px-3 py-2 text-sm hover:bg-slate-100 rounded" onclick="pinMessage()">
    📌 메시지 고정
  </button>
  <button class="w-full text-left px-3 py-2 text-sm hover:bg-slate-100 rounded" onclick="shareMessage()">
    🔗 메시지 공유
  </button>
  <div class="h-px bg-slate-200 my-1"></div>
  <button class="w-full text-left px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded" onclick="deleteMessage()">
    🗑️ 메시지 삭제
  </button>
</div>

<!-- Note Selection Modal -->
<div id="noteModal" class="fixed inset-0 hidden z-50 flex items-center justify-center" style="background-color: rgba(0, 0, 0, 0.2);" onclick="if(event.target === this) toggleNoteModal()">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl mx-4 max-h-[80vh] flex flex-col">
    <div class="border-b border-slate-200 px-6 py-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-slate-900">노트 선택</h3>
        <button onclick="toggleNoteModal()" class="p-1 hover:bg-slate-100 rounded">
          <%= icon "x", library: "tabler", class: "w-5 h-5 text-slate-500" %>
        </button>
      </div>
    </div>
    
    <div class="p-6 overflow-y-auto flex-1">
      <!-- Search bar -->
      <div class="mb-4">
        <input type="text" 
               placeholder="노트 검색..." 
               class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]"
               onkeyup="searchNotes(this.value)">
      </div>
      
      <!-- Notes list -->
      <div id="notes-list" class="space-y-2">
        <% if current_user && current_user.current_workspace %>
          <% current_user.current_workspace.notes.includes(:category, :status).order(updated_at: :desc).limit(20).each do |note| %>
            <div class="note-item border border-slate-200 rounded-lg p-4 hover:border-[#FF6D75] cursor-pointer transition-all" 
                 data-title="<%= note.title.downcase %>"
                 onclick="selectNote(<%= note.id %>, '<%= note.title %>', '<%= note.category.name %>', '<%= note.status.name %>')">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h4 class="font-medium text-slate-900"><%= note.title %></h4>
                  <p class="text-sm text-slate-600 mt-1 line-clamp-2"><%= note.body.truncate(100) %></p>
                  <div class="flex items-center gap-3 mt-2">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium" 
                          style="background-color: <%= note.category.color %>20; color: <%= note.category.color %>">
                      <%= note.category.name %>
                    </span>
                    <span class="text-xs text-slate-500"><%= note.updated_at.strftime("%m/%d") %></span>
                  </div>
                </div>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium" 
                      style="background-color: <%= note.status.color %>20; color: <%= note.status.color %>">
                  <%= note.status.name %>
                </span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Thread View Panel -->
<div id="threadPanel" class="hidden fixed right-0 top-0 h-full w-96 bg-white shadow-2xl z-40 flex flex-col">
  <!-- Thread Header -->
  <div class="px-4 py-3 border-b border-slate-200 flex items-center justify-between">
    <h3 class="text-base font-semibold text-slate-900">스레드</h3>
    <button onclick="closeThread()" class="p-1 hover:bg-slate-100 rounded">
      <%= icon "x", library: "tabler", class: "w-5 h-5 text-slate-500" %>
    </button>
  </div>
  
  <!-- Original Message -->
  <div id="threadOriginalMessage" class="p-4 border-b border-slate-100 bg-slate-50">
    <!-- Original message will be loaded here -->
  </div>
  
  <!-- Thread Messages -->
  <div id="threadMessages" class="flex-1 overflow-y-auto p-4">
    <!-- Thread replies will be loaded here -->
  </div>
  
  <!-- Thread Reply Input -->
  <div class="border-t border-slate-200 p-4">
    <form id="threadReplyForm" onsubmit="sendThreadReply(event)">
      <div class="flex items-center gap-3 bg-slate-50 rounded-lg px-4 py-3">
        <textarea name="reply_body" 
                  rows="2" 
                  class="flex-1 bg-transparent outline-none text-sm placeholder-slate-400 resize-none"
                  placeholder="답글을 입력하세요..."
                  onkeydown="handleThreadKeyPress(event)"></textarea>
        <button type="submit">
          <%= icon "send", library: "tabler", class: "w-5 h-5 text-slate-400 cursor-pointer hover:text-slate-600" %>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
let currentMessageId = null;
let currentEmojiPicker = null;
let isSubmitting = false;

// Pinned messages functionality
let pinnedMessages = <%= (@pinned_messages.any? ? @pinned_messages.map { |msg| 
  { 
    id: msg.id, 
    body: msg.body.truncate(100), 
    user_name: msg.user.name 
  } 
}.to_json.html_safe : '[]') %>;
let currentPinnedIndex = 0;

function cycleThroughPinnedMessages() {
  if (!pinnedMessages || pinnedMessages.length === 0) return;
  
  const currentPinnedMessage = pinnedMessages[currentPinnedIndex];
  const messageElement = document.getElementById(`message-${currentPinnedMessage.id}`);
  
  if (messageElement) {
    messageElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
    
    // Highlight temporarily
    messageElement.classList.add('bg-amber-100');
    setTimeout(() => {
      messageElement.classList.remove('bg-amber-100');
    }, 2000);
  }
  
  // Update to next message
  currentPinnedIndex = (currentPinnedIndex + 1) % pinnedMessages.length;
  
  // Update preview if multiple messages
  if (pinnedMessages.length > 1) {
    const nextMessage = pinnedMessages[currentPinnedIndex];
    const previewElement = document.getElementById('pinnedMessagePreview');
    if (previewElement) {
      previewElement.innerHTML = `<span class="font-medium">${nextMessage.user_name}</span>: ${nextMessage.body}`;
    }
  }
}

