<div class="max-w-7xl mx-auto">
  <div class="mb-8">
    <%= link_to admin_users_path, class: "inline-flex items-center text-sm text-slate-600 hover:text-slate-900" do %>
      <%= icon "arrow-left", class: "w-4 h-4 mr-1" %>
      사용자 목록으로 돌아가기
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6 mb-6">
    <div class="flex items-start justify-between">
      <div class="flex items-center">
        <div class="h-16 w-16 rounded-full bg-[#FF6D75] flex items-center justify-center">
          <span class="text-white text-2xl font-medium">
            <%= @user.name.present? ? @user.name.first.upcase : @user.email.first.upcase %>
          </span>
        </div>
        <div class="ml-4">
          <h1 class="text-2xl font-bold text-slate-900">
            <%= @user.name || "이름 없음" %>
          </h1>
          <p class="text-slate-600"><%= @user.email %></p>
        </div>
      </div>
      
      <div class="flex items-center gap-2">
        <%= button_to toggle_admin_admin_user_path(@user), method: :patch, class: "inline-flex items-center px-3 py-2 border border-slate-300 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50", data: { turbo_confirm: @user.admin? ? "관리자 권한을 제거하시겠습니까?" : "관리자 권한을 부여하시겠습니까?" } do %>
          <% if @user.admin? %>
            <%= icon "shield-off", class: "w-4 h-4 mr-2" %>
            관리자 권한 제거
          <% else %>
            <%= icon "shield-check", class: "w-4 h-4 mr-2" %>
            관리자 권한 부여
          <% end %>
        <% end %>
        
        <%= link_to edit_admin_user_path(@user), class: "inline-flex items-center px-3 py-2 border border-slate-300 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50" do %>
          <%= icon "pencil", class: "w-4 h-4 mr-2" %>
          편집
        <% end %>
        
        <% unless @user == current_user %>
          <%= button_to admin_user_path(@user), method: :delete, class: "inline-flex items-center px-3 py-2 border border-red-300 rounded-md text-sm font-medium text-red-700 bg-white hover:bg-red-50", data: { turbo_confirm: "정말로 이 사용자를 삭제하시겠습니까?" } do %>
            <%= icon "trash", class: "w-4 h-4 mr-2" %>
            삭제
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">사용자 정보</h2>
        
        <dl class="space-y-3">
          <div>
            <dt class="text-sm font-medium text-slate-500">권한</dt>
            <dd class="mt-1">
              <% if @user.admin? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                  관리자
                </span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-slate-100 text-slate-800">
                  일반 사용자
                </span>
              <% end %>
            </dd>
          </div>
          
          <div>
            <dt class="text-sm font-medium text-slate-500">가입일</dt>
            <dd class="mt-1 text-sm text-slate-900">
              <%= @user.created_at.strftime("%Y년 %m월 %d일") %>
            </dd>
          </div>
          
          <div>
            <dt class="text-sm font-medium text-slate-500">마지막 로그인</dt>
            <dd class="mt-1 text-sm text-slate-900">
              <% if @user.last_sign_in_at.present? %>
                <%= @user.last_sign_in_at.strftime("%Y년 %m월 %d일 %H:%M") %>
              <% else %>
                로그인 기록 없음
              <% end %>
            </dd>
          </div>
          
          <div>
            <dt class="text-sm font-medium text-slate-500">로그인 횟수</dt>
            <dd class="mt-1 text-sm text-slate-900">
              <%= @user.sign_in_count || 0 %>회
            </dd>
          </div>
        </dl>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6 mt-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">워크스페이스</h2>
        
        <% if @workspaces.any? %>
          <ul class="space-y-2">
            <% @workspaces.each do |workspace| %>
              <li class="flex items-center justify-between py-2">
                <span class="text-sm text-slate-900"><%= workspace.name %></span>
                <span class="text-xs text-slate-500">
                  <%= workspace.user_workspaces.find_by(user: @user).role %>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-slate-500">워크스페이스가 없습니다.</p>
        <% end %>
      </div>
    </div>
    
    <div class="lg:col-span-2">
      <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">최근 활동</h2>
        
        <% if @notes.any? %>
          <div class="space-y-4">
            <% @notes.each do |note| %>
              <div class="border-b border-slate-200 pb-4 last:border-0">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <p class="text-sm text-slate-900 line-clamp-2">
                      <%= note.content %>
                    </p>
                    <div class="mt-1 flex items-center text-xs text-slate-500">
                      <span><%= note.workspace.name %></span>
                      <span class="mx-2">•</span>
                      <span><%= note.created_at.strftime("%Y-%m-%d %H:%M") %></span>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">활동 내역이 없습니다.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>