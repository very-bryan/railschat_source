<div class="max-w-4xl mx-auto">
  <div class="mb-8">
    <%= link_to admin_user_path(@user), class: "inline-flex items-center text-sm text-slate-600 hover:text-slate-900" do %>
      <%= icon "arrow-left", class: "w-4 h-4 mr-1" %>
      사용자 상세로 돌아가기
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6">
    <h1 class="text-2xl font-bold text-slate-900 mb-6">사용자 정보 수정</h1>
    
    <%= form_with model: @user, url: admin_user_path(@user), local: true do |form| %>
      <% if @user.errors.any? %>
        <div class="rounded-md bg-red-50 p-4 mb-6">
          <div class="flex">
            <div class="flex-shrink-0">
              <%= icon "alert-circle", class: "h-5 w-5 text-red-400" %>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">
                <%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:
              </h3>
              <div class="mt-2 text-sm text-red-700">
                <ul class="list-disc list-inside">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <%= form.label :email, class: "block text-sm font-medium text-slate-700" %>
          <%= form.email_field :email, class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-[#FF6D75] focus:ring-[#FF6D75] sm:text-sm" %>
        </div>

        <div>
          <%= form.label :name, "이름", class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-[#FF6D75] focus:ring-[#FF6D75] sm:text-sm" %>
        </div>

        <div>
          <%= form.label :role, "역할", class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_field :role, class: "mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-[#FF6D75] focus:ring-[#FF6D75] sm:text-sm", placeholder: "예: 개발자, 디자이너, 관리자" %>
          <p class="mt-1 text-sm text-slate-500">사용자의 직무나 역할을 입력하세요.</p>
        </div>
      </div>

      <div class="mt-6 flex items-center justify-end gap-3">
        <%= link_to "취소", admin_user_path(@user), class: "px-4 py-2 border border-slate-300 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50" %>
        <%= form.submit "저장", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[#FF6D75] hover:bg-[#FF5561] cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>