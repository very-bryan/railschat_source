<% content_for(:page_title, "노트 관리") %>

<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-slate-900">노트 관리</h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            내용
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            작성자
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            워크스페이스
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            작성일
          </th>
          <th class="relative px-6 py-3">
            <span class="sr-only">작업</span>
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-slate-200">
        <% @notes.each do |note| %>
          <tr class="hover:bg-slate-50">
            <td class="px-6 py-4">
              <div class="text-sm text-slate-900 max-w-md truncate">
                <%= note.content %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if note.user.present? %>
                <div class="flex items-center">
                  <div class="h-8 w-8 rounded-full bg-[#FF6D75] flex items-center justify-center mr-2">
                    <span class="text-white text-xs font-medium">
                      <%= note.user.name.present? ? note.user.name.first.upcase : note.user.email.first.upcase %>
                    </span>
                  </div>
                  <div class="text-sm">
                    <div class="text-slate-900"><%= note.user.name || note.user.email %></div>
                  </div>
                </div>
              <% else %>
                <span class="text-sm text-slate-500">익명</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-slate-900">
                <%= note.workspace.name %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
              <%= note.created_at.strftime("%Y-%m-%d %H:%M") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <div class="flex items-center justify-end gap-2">
                <%= link_to admin_note_path(note), class: "text-[#FF6D75] hover:text-[#FF5561]" do %>
                  <%= icon "eye", class: "w-4 h-4" %>
                <% end %>
                
                <%= button_to admin_note_path(note), method: :delete, class: "text-red-600 hover:text-red-900", data: { turbo_confirm: "정말로 이 노트를 삭제하시겠습니까?" } do %>
                  <%= icon "trash", class: "w-4 h-4" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  
  <% if @notes.respond_to?(:current_page) %>
    <div class="mt-6 flex justify-center">
      <%= paginate @notes %>
    </div>
  <% end %>
</div>