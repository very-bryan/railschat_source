<% content_for :page_title, "검색" %>

<div class="max-w-6xl mx-auto px-4 py-8 space-y-6">
  <!-- Search Header -->
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6">
    <h1 class="text-2xl font-bold text-slate-900 mb-4">통합 검색</h1>
    
    <!-- Search Form -->
    <%= form_with url: search_path, method: :get, local: true, class: "space-y-4" do |form| %>
      <div class="flex space-x-4">
        <div class="flex-1">
          <%= form.text_field :q, 
              value: @query,
              placeholder: "노트, 채널, 메시지, 사용자 검색...",
              class: "w-full px-4 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]",
              autofocus: true %>
        </div>
        <div>
          <%= form.select :filter, 
              options_for_select([
                ['전체', 'all'],
                ['노트', 'notes'],
                ['채널', 'channels'],
                ['메시지', 'messages'],
                ['사용자', 'users']
              ], @filter),
              {},
              { class: "px-4 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]" } %>
        </div>
        <div>
          <%= form.submit "검색", class: "px-4 py-2 bg-[#FF6D75] text-white rounded-md text-sm font-medium hover:bg-[#FF5561] focus:outline-none focus:ring-2 focus:ring-[#FF6D75] cursor-pointer" %>
        </div>
      </div>
    <% end %>

    <!-- Recent Searches -->
    <% if @recent_searches.any? %>
      <div class="mt-4">
        <h3 class="text-sm font-medium text-slate-700 mb-2">최근 검색어</h3>
        <div class="flex flex-wrap gap-2">
          <% @recent_searches.each do |search| %>
            <%= link_to search_path(q: search), class: "inline-flex items-center px-3 py-1 rounded-full text-xs bg-slate-100 text-slate-700 hover:bg-slate-200" do %>
              <%= icon "search", class: "w-3 h-3 mr-1" %>
              <%= search %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Search Results -->
  <% if @query.present? %>
    <% if @results.any? { |_, results| results&.any? } %>
      <div class="space-y-6">
        <!-- Notes Results -->
        <% if @results[:notes]&.any? %>
          <div class="bg-white rounded-lg shadow-sm border border-slate-200">
            <div class="px-6 py-4 border-b border-slate-200">
              <h3 class="text-lg font-semibold text-slate-900">노트 (<%= @results[:notes].count %>)</h3>
            </div>
            <div class="divide-y divide-slate-200">
              <% @results[:notes].each do |note| %>
                <div class="px-6 py-4 hover:bg-slate-50">
                  <div class="flex items-start space-x-3">
                    <div class="w-3 h-3 rounded-full mt-1" style="background-color: <%= note.category.color %>"></div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between">
                        <div>
                          <%= link_to note.title, note_path(note), class: "text-base font-medium text-slate-900 hover:text-[#FF6D75]" %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ml-2"
                                style="background-color: <%= note.status.color %>20; color: <%= note.status.color %>;">
                            <%= note.status.name %>
                          </span>
                        </div>
                        <div class="text-sm text-slate-500">
                          <%= time_ago_in_words(note.updated_at) %>전
                        </div>
                      </div>
                      <p class="text-sm text-slate-600 mt-1">
                        <%= truncate(note.body, length: 150) %>
                      </p>
                      <div class="flex items-center space-x-4 mt-2 text-xs text-slate-500">
                        <span><%= note.category.name %></span>
                        <span>작성자: <%= note.user.name %></span>
                        <% if note.assignees.any? %>
                          <span>담당자: <%= note.assignees.map(&:name).join(', ') %></span>
                        <% end %>
                        <% if note.attachments.any? %>
                          <span class="flex items-center">
                            <%= icon "paperclip", class: "w-3 h-3 mr-1" %>
                            <%= note.attachments.count %>개 첨부
                          </span>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Channels Results -->
        <% if @results[:channels]&.any? %>
          <div class="bg-white rounded-lg shadow-sm border border-slate-200">
            <div class="px-6 py-4 border-b border-slate-200">
              <h3 class="text-lg font-semibold text-slate-900">채널 (<%= @results[:channels].count %>)</h3>
            </div>
            <div class="divide-y divide-slate-200">
              <% @results[:channels].each do |channel| %>
                <div class="px-6 py-4 hover:bg-slate-50">
                  <div class="flex items-start space-x-3">
                    <div class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center">
                      <%= icon channel.is_private? ? "lock" : "hash", class: "w-4 h-4 text-slate-600" %>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between">
                        <div>
                          <%= link_to chat_channel_path(channel), class: "text-base font-medium text-slate-900 hover:text-[#FF6D75]" do %>
                            #<%= channel.name %>
                          <% end %>
                          <% if channel.is_private? %>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 ml-2">
                              비공개
                            </span>
                          <% end %>
                        </div>
                        <div class="text-sm text-slate-500">
                          <%= pluralize(channel.channel_members.count, '명') %>
                        </div>
                      </div>
                      <% if channel.description.present? %>
                        <p class="text-sm text-slate-600 mt-1">
                          <%= truncate(channel.description, length: 100) %>
                        </p>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Messages Results -->
        <% if @results[:messages]&.any? %>
          <div class="bg-white rounded-lg shadow-sm border border-slate-200">
            <div class="px-6 py-4 border-b border-slate-200">
              <h3 class="text-lg font-semibold text-slate-900">메시지 (<%= @results[:messages].count %>)</h3>
            </div>
            <div class="divide-y divide-slate-200">
              <% @results[:messages].each do |message| %>
                <div class="px-6 py-4 hover:bg-slate-50">
                  <div class="flex items-start space-x-3">
                    <div class="w-8 h-8 bg-[#FF6D75] rounded-full flex items-center justify-center text-sm font-medium text-white">
                      <%= message.user.name.first.upcase %>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="text-sm font-medium text-slate-900">
                            <%= message.user.name %>
                          </span>
                          <span class="text-sm text-slate-500">
                            <%= link_to chat_channel_path(message.channel), class: "text-[#FF6D75] hover:text-[#FF5561]" do %>
                              #<%= message.channel.name %>
                            <% end %>
                          </span>
                        </div>
                        <div class="text-sm text-slate-500">
                          <%= time_ago_in_words(message.created_at) %>전
                        </div>
                      </div>
                      <p class="text-sm text-slate-700 mt-1">
                        <%= simple_format(truncate(message.content, length: 200)) %>
                      </p>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Users Results -->
        <% if @results[:users]&.any? %>
          <div class="bg-white rounded-lg shadow-sm border border-slate-200">
            <div class="px-6 py-4 border-b border-slate-200">
              <h3 class="text-lg font-semibold text-slate-900">사용자 (<%= @results[:users].count %>)</h3>
            </div>
            <div class="divide-y divide-slate-200">
              <% @results[:users].each do |user| %>
                <div class="px-6 py-4 hover:bg-slate-50">
                  <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-[#FF6D75] rounded-full flex items-center justify-center text-sm font-medium text-white">
                      <%= user.name.first.upcase %>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between">
                        <div>
                          <p class="text-sm font-medium text-slate-900">
                            <%= user.name %>
                          </p>
                          <p class="text-sm text-slate-500"><%= user.email %></p>
                        </div>
                        <div class="text-sm text-slate-500">
                          <%= user.role&.humanize || '사용자' %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- No Results -->
      <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-12">
        <div class="text-center">
          <div class="w-12 h-12 bg-slate-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <%= icon "search-off", class: "w-6 h-6 text-slate-400" %>
          </div>
          <h3 class="text-lg font-medium text-slate-900 mb-2">검색 결과가 없습니다</h3>
          <p class="text-sm text-slate-500 mb-6">
            "<%= @query %>"에 대한 검색 결과를 찾을 수 없습니다.
          </p>
          <div class="text-sm text-slate-500">
            <p>검색 팁:</p>
            <ul class="mt-2 space-y-1">
              <li>• 키워드를 다시 확인해보세요</li>
              <li>• 더 일반적인 검색어를 사용해보세요</li>
              <li>• 필터를 변경해보세요</li>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <!-- Search Tips -->
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-[#FFF0F1] rounded-full flex items-center justify-center mx-auto mb-4">
          <%= icon "search", class: "w-8 h-8 text-[#FF6D75]" %>
        </div>
        <h3 class="text-lg font-medium text-slate-900 mb-2">통합 검색</h3>
        <p class="text-sm text-slate-500 mb-6">
          노트, 채널, 메시지, 사용자를 한 번에 검색할 수 있습니다.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left max-w-2xl mx-auto">
          <div>
            <h4 class="font-medium text-slate-900 mb-2">검색 가능한 항목</h4>
            <ul class="text-sm text-slate-600 space-y-1">
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>노트 제목과 내용</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>채널 이름과 설명</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>채팅 메시지</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>사용자 이름과 이메일</span>
              </li>
            </ul>
          </div>
          <div>
            <h4 class="font-medium text-slate-900 mb-2">검색 팁</h4>
            <ul class="text-sm text-slate-600 space-y-1">
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>키워드 일부만 입력해도 됩니다</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>필터를 사용해 특정 항목만 검색</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>최근 검색어를 클릭해 빠른 재검색</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>