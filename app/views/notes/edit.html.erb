<% content_for :page_title, "노트 수정" %>

<div class="max-w-4xl mx-auto">
  <div class="bg-white rounded-xl border border-slate-100">
    <div class="px-6 py-4 border-b border-slate-100">
      <h3 class="text-base font-semibold text-slate-900">노트 수정</h3>
      <p class="text-sm text-slate-500">노트 정보를 수정합니다</p>
    </div>
    
    <div class="p-6">
      <%= form_with model: @note, local: true, class: "space-y-6" do |form| %>
        <% if @note.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <%= icon "alert-circle", library: "tabler", class: "w-5 h-5 text-red-400" %>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  <%= pluralize(@note.errors.count, "error") %> 오류가 발생했습니다:
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc list-inside">
                    <% @note.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Left Column -->
          <div class="space-y-6">
            <!-- Title -->
            <div>
              <%= form.label :title, "제목", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.text_field :title, 
                                 class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]",
                                 placeholder: "노트 제목을 입력하세요" %>
            </div>

            <!-- Category -->
            <div>
              <%= form.label :category_id, "카테고리", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.select :category_id, 
                             options_from_collection_for_select(@categories, :id, :name, @note.category_id),
                             { prompt: "카테고리를 선택하세요" },
                             { class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]" } %>
            </div>

            <!-- Status -->
            <div>
              <%= form.label :status_id, "상태", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.select :status_id, 
                             options_from_collection_for_select(@statuses, :id, :name, @note.status_id),
                             { prompt: "상태를 선택하세요" },
                             { class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]" } %>
            </div>

            <!-- Parent Note -->
            <div>
              <%= form.label :parent_id, "부모 노트", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.select :parent_id, 
                             options_from_collection_for_select(current_user.notes.where.not(id: @note.id), :id, :title, @note.parent_id),
                             { prompt: "부모 노트를 선택하세요 (선택사항)" },
                             { class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]" } %>
              <p class="text-xs text-slate-500 mt-1">이 노트를 다른 노트의 하위 작업으로 설정할 수 있습니다</p>
            </div>
          </div>

          <!-- Right Column -->
          <div class="space-y-6">
            <!-- Assignees -->
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">담당자</label>
              <div class="space-y-2">
                <% @users.each do |user| %>
                  <div class="flex items-center">
                    <%= check_box_tag "assignee_ids[]", user.id, @note.assignees.include?(user), 
                                     class: "h-4 w-4 text-[#FF6D75] focus:ring-[#FF6D75] border-slate-300 rounded" %>
                    <label class="ml-2 block text-sm text-slate-700">
                      <%= user.full_name.present? ? user.full_name : user.email %>
                      <span class="text-xs text-slate-500">(<%= user.email %>)</span>
                    </label>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Dates -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= form.label :start_date, "시작일", class: "block text-sm font-medium text-slate-700 mb-1" %>
                <%= form.date_field :start_date, 
                                   class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]" %>
              </div>

              <div>
                <%= form.label :due_date, "마감일", class: "block text-sm font-medium text-slate-700 mb-1" %>
                <%= form.date_field :due_date, 
                                   class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]" %>
              </div>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div>
          <%= form.label :body, "내용", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.text_area :body, 
                            rows: 8,
                            class: "block w-full px-3 py-2 border border-slate-200 rounded-md text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]",
                            placeholder: "노트 내용을 입력하세요..." %>
        </div>

        <!-- Existing Attachments -->
        <% if @note.attachments.any? %>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">기존 첨부 파일</label>
            <div class="space-y-2">
              <% @note.attachments.each do |attachment| %>
                <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                  <div class="flex items-center gap-2">
                    <%= icon "paperclip", library: "tabler", class: "w-4 h-4 text-slate-500" %>
                    <span class="text-sm text-slate-900"><%= attachment.filename %></span>
                    <span class="text-xs text-slate-500">(<%= number_to_human_size(attachment.byte_size) %>)</span>
                  </div>
                  <%= link_to "다운로드", rails_blob_path(attachment, disposition: "attachment"), 
                             class: "text-[#FF6D75] hover:text-[#E85560] text-sm transition-colors" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- File Attachments -->
        <div>
          <%= form.label :attachments, "새 파일 첨부", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.file_field :attachments, 
                             multiple: true,
                             class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-[#FFF0F1] file:text-[#E85560] hover:file:bg-[#FFE0E2]" %>
          <p class="text-xs text-slate-500 mt-1">여러 파일을 선택하여 첨부할 수 있습니다. 새 파일은 기존 파일에 추가됩니다</p>
        </div>

        <!-- Actions -->
        <div class="flex items-center justify-end gap-4 pt-6 border-t border-slate-200">
          <%= link_to "취소", @note, class: "px-4 py-2 border border-slate-200 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-[#FF6D75]" %>
          <%= form.submit "노트 수정", class: "px-4 py-2 bg-[#FF6D75] text-white rounded-md hover:bg-[#E85560] focus:outline-none focus:ring-2 focus:ring-[#FF6D75] text-sm font-medium" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
