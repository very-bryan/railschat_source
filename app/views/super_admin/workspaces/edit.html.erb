<% content_for :page_title, "워크스페이스 편집" %>

<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-lg shadow-sm border border-slate-200">
    <div class="px-6 py-4 border-b border-slate-200">
      <h2 class="text-lg font-semibold text-slate-900">워크스페이스 정보 수정</h2>
    </div>
    
    <%= form_with model: @workspace, url: super_admin_workspace_path(@workspace), local: true, class: "p-6" do |form| %>
      <% if @workspace.errors.any? %>
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-md">
          <div class="flex">
            <%= icon "alert-circle", class: "w-5 h-5 text-red-400 mr-2" %>
            <div>
              <h3 class="text-sm font-medium text-red-800">
                <%= pluralize(@workspace.errors.count, "개의 오류") %>가 발생했습니다:
              </h3>
              <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                <% @workspace.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <%= form.label :name, "워크스페이스 이름", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.text_field :name, 
              class: "w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent",
              placeholder: "워크스페이스 이름" %>
        </div>

        <div>
          <%= form.label :description, "설명", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.text_area :description, 
              rows: 3,
              class: "w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent",
              placeholder: "워크스페이스에 대한 간단한 설명을 입력하세요" %>
        </div>

        <div class="space-y-4">
          <h3 class="text-sm font-medium text-slate-900">워크스페이스 설정</h3>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= form.label :max_members, "최대 멤버 수", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.number_field :max_members, 
                  class: "w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent",
                  placeholder: "무제한인 경우 비워두세요" %>
              <p class="text-xs text-slate-500 mt-1">현재 멤버: <%= @workspace.users.count %>명</p>
            </div>
            
            <div>
              <%= form.label :max_storage_mb, "최대 스토리지 (MB)", class: "block text-sm font-medium text-slate-700 mb-1" %>
              <%= form.number_field :max_storage_mb, 
                  class: "w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent",
                  placeholder: "무제한인 경우 비워두세요" %>
              <p class="text-xs text-slate-500 mt-1">
                현재 사용량: <%= number_to_human_size(@workspace.notes.joins(attachments_attachments: :blob).sum('active_storage_blobs.byte_size')) %>
              </p>
            </div>
          </div>
          
          <label class="flex items-center p-4 bg-slate-50 rounded-lg cursor-pointer hover:bg-slate-100">
            <%= form.check_box :is_active, class: "w-4 h-4 text-purple-600 border-slate-300 rounded focus:ring-purple-500" %>
            <div class="ml-3">
              <span class="text-sm font-medium text-slate-900">활성화 상태</span>
              <p class="text-xs text-slate-500 mt-1">
                비활성화하면 멤버들이 워크스페이스에 접근할 수 없습니다
              </p>
            </div>
          </label>
        </div>

        <!-- Workspace Information -->
        <div class="border-t border-slate-200 pt-6">
          <h3 class="text-sm font-medium text-slate-900 mb-3">워크스페이스 정보</h3>
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div>
              <p class="text-slate-500">생성일</p>
              <p class="font-medium text-slate-900"><%= @workspace.created_at.strftime("%Y년 %m월 %d일") %></p>
            </div>
            <div>
              <p class="text-slate-500">마지막 활동</p>
              <p class="font-medium text-slate-900">
                <% last_activity = @workspace.notes.maximum(:created_at) %>
                <% if last_activity %>
                  <%= last_activity.strftime("%Y년 %m월 %d일 %H:%M") %>
                <% else %>
                  -
                <% end %>
              </p>
            </div>
            <div>
              <p class="text-slate-500">총 노트 수</p>
              <p class="font-medium text-slate-900"><%= number_with_delimiter(@workspace.notes.count) %>개</p>
            </div>
            <div>
              <p class="text-slate-500">총 채널 수</p>
              <p class="font-medium text-slate-900"><%= number_with_delimiter(@workspace.channels.count) %>개</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 flex items-center justify-between">
        <%= link_to "취소", super_admin_workspace_path(@workspace), 
            class: "px-4 py-2 bg-white border border-slate-300 text-slate-700 rounded-md hover:bg-slate-50" %>
        
        <%= form.submit "변경사항 저장", 
            class: "px-4 py-2 bg-purple-600 text-white rounded-md hover:bg-purple-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>