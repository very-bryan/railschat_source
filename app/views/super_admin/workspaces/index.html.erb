<% content_for :page_title, "워크스페이스 관리" %>

<div class="space-y-6">
  <!-- Filters -->
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
    <%= form_with url: super_admin_workspaces_path, method: :get, class: "flex items-center gap-4" do |form| %>
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">상태</label>
        <%= select_tag :status, 
            options_for_select([
              ['전체', ''],
              ['활성', 'active'],
              ['비활성', 'inactive']
            ], params[:status]),
            class: "px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600" %>
      </div>
      
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">규모</label>
        <%= select_tag :size,
            options_for_select([
              ['전체', ''],
              ['소규모 (1-5명)', 'small'],
              ['중규모 (6-20명)', 'medium'],
              ['대규모 (20명+)', 'large']
            ], params[:size]),
            class: "px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600" %>
      </div>
      
      <%= submit_tag "필터 적용", class: "mt-5 px-4 py-2 bg-purple-600 text-white rounded-md text-sm hover:bg-purple-700" %>
    <% end %>
  </div>

  <!-- Workspaces Table -->
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            워크스페이스
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            소유자
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            멤버
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            노트
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            스토리지
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            생성일
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
            상태
          </th>
          <th class="relative px-6 py-3">
            <span class="sr-only">작업</span>
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-slate-200">
        <% @workspaces.each do |workspace| %>
          <% owner = workspace.workspace_members.find_by(role: 'admin')&.user %>
          <% storage_used = workspace.notes.joins(attachments_attachments: :blob).sum('active_storage_blobs.byte_size') %>
          <% last_activity = workspace.notes.maximum(:created_at) %>
          <% is_active = last_activity && last_activity > 7.days.ago %>
          
          <tr class="hover:bg-slate-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div>
                <div class="text-sm font-medium text-slate-900">
                  <%= link_to workspace.name, super_admin_workspace_path(workspace), class: "hover:text-purple-600" %>
                </div>
                <% if workspace.description.present? %>
                  <div class="text-xs text-slate-500 truncate max-w-xs">
                    <%= workspace.description %>
                  </div>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if owner %>
                <div class="text-sm text-slate-900"><%= owner.name %></div>
                <div class="text-xs text-slate-500"><%= owner.email %></div>
              <% else %>
                <span class="text-sm text-slate-500">-</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-slate-900">
                <%= workspace.users.count %>명
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-slate-900">
                <%= number_with_delimiter(workspace.notes.count) %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-slate-900">
                <%= number_to_human_size(storage_used) %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-slate-500">
                <%= workspace.created_at.strftime("%Y-%m-%d") %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if is_active %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                  활성
                </span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-slate-100 text-slate-800">
                  비활성
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <div class="flex items-center justify-end gap-2">
                <%= link_to super_admin_workspace_path(workspace), class: "text-purple-600 hover:text-purple-900" do %>
                  <%= icon "eye", class: "w-4 h-4" %>
                <% end %>
                
                <%= link_to edit_super_admin_workspace_path(workspace), class: "text-slate-600 hover:text-slate-900" do %>
                  <%= icon "pencil", class: "w-4 h-4" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    
    <% if @workspaces.respond_to?(:current_page) %>
      <div class="px-6 py-4 border-t border-slate-200">
        <%= paginate @workspaces %>
      </div>
    <% end %>
  </div>
</div>