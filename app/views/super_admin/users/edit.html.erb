<% content_for :page_title, "사용자 편집" %>

<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-lg shadow-sm border border-slate-200">
    <div class="px-6 py-4 border-b border-slate-200">
      <h2 class="text-lg font-semibold text-slate-900">사용자 정보 수정</h2>
    </div>
    
    <%= form_with model: @user, url: super_admin_user_path(@user), local: true, class: "p-6" do |form| %>
      <% if @user.errors.any? %>
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-md">
          <div class="flex">
            <%= icon "alert-circle", class: "w-5 h-5 text-red-400 mr-2" %>
            <div>
              <h3 class="text-sm font-medium text-red-800">
                <%= pluralize(@user.errors.count, "개의 오류") %>가 발생했습니다:
              </h3>
              <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <%= form.label :email, "이메일", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.email_field :email, 
              class: "w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent",
              placeholder: "user@example.com" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= form.label :first_name, "이름", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= form.text_field :first_name, 
                class: "w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent" %>
          </div>
          
          <div>
            <%= form.label :last_name, "성", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= form.text_field :last_name, 
                class: "w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent" %>
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-sm font-medium text-slate-900">권한 설정</h3>
          
          <div class="space-y-3">
            <% unless @user == current_user %>
              <label class="flex items-center p-4 bg-slate-50 rounded-lg cursor-pointer hover:bg-slate-100">
                <%= form.check_box :super_admin, class: "w-4 h-4 text-purple-600 border-slate-300 rounded focus:ring-purple-500" %>
                <div class="ml-3">
                  <span class="text-sm font-medium text-slate-900">슈퍼 관리자</span>
                  <p class="text-xs text-slate-500 mt-1">
                    모든 워크스페이스와 사용자를 관리할 수 있는 최고 권한입니다
                  </p>
                </div>
              </label>
            <% end %>
            
            <label class="flex items-center p-4 bg-slate-50 rounded-lg cursor-pointer hover:bg-slate-100">
              <%= form.check_box :admin, class: "w-4 h-4 text-purple-600 border-slate-300 rounded focus:ring-purple-500" %>
              <div class="ml-3">
                <span class="text-sm font-medium text-slate-900">워크스페이스 관리자</span>
                <p class="text-xs text-slate-500 mt-1">
                  소속된 워크스페이스를 관리할 수 있습니다
                </p>
              </div>
            </label>
          </div>
        </div>

        <!-- Account Information -->
        <div class="border-t border-slate-200 pt-6">
          <h3 class="text-sm font-medium text-slate-900 mb-3">계정 정보</h3>
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div>
              <p class="text-slate-500">가입일</p>
              <p class="font-medium text-slate-900"><%= @user.created_at.strftime("%Y년 %m월 %d일") %></p>
            </div>
            <div>
              <p class="text-slate-500">마지막 로그인</p>
              <p class="font-medium text-slate-900">
                <% if @user.last_sign_in_at %>
                  <%= @user.last_sign_in_at.strftime("%Y년 %m월 %d일 %H:%M") %>
                <% else %>
                  -
                <% end %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 flex items-center justify-between">
        <%= link_to "취소", super_admin_user_path(@user), 
            class: "px-4 py-2 bg-white border border-slate-300 text-slate-700 rounded-md hover:bg-slate-50" %>
        
        <%= form.submit "변경사항 저장", 
            class: "px-4 py-2 bg-purple-600 text-white rounded-md hover:bg-purple-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>