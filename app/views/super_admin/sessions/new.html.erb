<div class="w-full max-w-md">
  <div class="bg-slate-800 shadow-2xl rounded-lg px-8 pt-8 pb-8">
    <!-- Logo -->
    <div class="flex flex-col items-center mb-8">
      <div class="w-16 h-16 bg-gradient-to-br from-purple-600 to-purple-800 rounded-lg flex items-center justify-center mb-4">
        <span class="text-white font-bold text-2xl">SA</span>
      </div>
      <h1 class="text-2xl font-bold text-white">슈퍼 관리자</h1>
      <p class="text-slate-400 text-sm mt-1">시스템 관리 패널</p>
    </div>

    <!-- Flash Messages -->
    <% if alert.present? %>
      <div class="mb-4 p-3 bg-red-900/50 border border-red-700 text-red-200 rounded-md text-sm">
        <%= alert %>
      </div>
    <% end %>
    
    <% if notice.present? %>
      <div class="mb-4 p-3 bg-emerald-900/50 border border-emerald-700 text-emerald-200 rounded-md text-sm">
        <%= notice %>
      </div>
    <% end %>

    <!-- Login Form -->
    <%= form_with url: super_admin_sessions_path, local: true do |form| %>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1">
            이메일
          </label>
          <%= email_field_tag :email, nil, 
              class: "w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-md text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent",
              placeholder: "admin@example.com",
              required: true,
              autofocus: true %>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1">
            비밀번호
          </label>
          <%= password_field_tag :password, nil,
              class: "w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-md text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-purple-600 focus:border-transparent",
              placeholder: "••••••••",
              required: true %>
        </div>

        <div class="pt-2">
          <%= submit_tag "로그인", 
              class: "w-full px-4 py-2 bg-purple-600 text-white font-medium rounded-md hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-600 focus:ring-offset-2 focus:ring-offset-slate-800 cursor-pointer" %>
        </div>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <p class="text-xs text-slate-400">
        슈퍼 관리자 권한이 있는 계정만 접근 가능합니다
      </p>
      <%= link_to "일반 로그인으로 돌아가기", new_user_session_path, 
          class: "text-xs text-purple-400 hover:text-purple-300 mt-2 inline-block" %>
    </div>
  </div>

  <div class="mt-8 text-center">
    <p class="text-xs text-slate-500">
      보안 경고: 이 페이지는 시스템 관리자 전용입니다.<br>
      모든 접속 시도는 기록됩니다.
    </p>
  </div>
</div>