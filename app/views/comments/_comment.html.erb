<div id="<%= dom_id(comment) %>" class="flex space-x-3 py-4">
  <div class="flex-shrink-0">
    <div class="w-8 h-8 bg-[#FF6D75] rounded-full flex items-center justify-center text-sm font-medium text-white">
      <%= comment.user.name.first.upcase %>
    </div>
  </div>
  
  <div class="flex-1">
    <div class="bg-slate-50 rounded-lg p-4">
      <div class="flex items-start justify-between">
        <div>
          <span class="text-sm font-medium text-slate-900"><%= comment.user.name %></span>
          <span class="text-xs text-slate-500 ml-2"><%= time_ago_in_words(comment.created_at) %>전</span>
        </div>
        
        <% if comment.user == current_user || current_user.admin? %>
          <%= button_to note_comment_path(comment.commentable, comment), method: :delete, class: "text-slate-400 hover:text-red-600", data: { turbo_confirm: "댓글을 삭제하시겠습니까?" } do %>
            <%= icon "trash", class: "w-4 h-4" %>
          <% end %>
        <% end %>
      </div>
      
      <div class="mt-2 text-sm text-slate-700">
        <%= simple_format(comment.content) %>
      </div>
      
      <% if comment.attachments.any? %>
        <div class="mt-3 space-y-2">
          <% comment.attachments.each do |attachment| %>
            <div class="flex items-center space-x-2 text-sm">
              <%= icon "paperclip", class: "w-4 h-4 text-slate-400" %>
              <%= link_to attachment.filename, rails_blob_path(attachment, disposition: "attachment"), class: "text-[#FF6D75] hover:text-[#FF5561]" %>
              <span class="text-slate-500">(<%= number_to_human_size(attachment.byte_size) %>)</span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>