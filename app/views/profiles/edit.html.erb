<div class="min-h-screen bg-slate-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 페이지 헤더 -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">프로필 편집</h1>
      <p class="mt-2 text-sm text-slate-600">개인정보를 수정하세요</p>
    </div>

    <!-- 편집 폼 -->
    <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-6", html: { multipart: true } do |form| %>
      <div class="bg-white rounded-lg shadow-sm border border-slate-200">
        <div class="p-6 space-y-6">
          <!-- 프로필 이미지 섹션 -->
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-4">
              프로필 이미지
            </label>
            <div class="flex items-center space-x-4">
              <div id="avatar-preview">
                <% if @user.avatar_url.present? %>
                  <%= image_tag @user.avatar_url, alt: @user.full_name, class: "h-20 w-20 rounded-full object-cover" %>
                <% else %>
                  <div class="h-20 w-20 rounded-full bg-gradient-to-br from-[#FF6D75] to-[#E85560] flex items-center justify-center text-white text-2xl font-semibold">
                    <%= @user.full_name.first.upcase %>
                  </div>
                <% end %>
              </div>
              <div>
                <%= form.file_field :avatar, 
                    id: "avatar-upload",
                    accept: "image/*",
                    class: "hidden",
                    onchange: "previewAvatar(this);" %>
                <label for="avatar-upload" class="inline-flex items-center px-3 py-2 border border-slate-300 rounded-md shadow-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#FF6D75] cursor-pointer">
                  <%= icon "upload", library: "tabler", class: "w-4 h-4 mr-2" %>
                  이미지 변경
                </label>
                <p class="mt-2 text-xs text-slate-500">
                  JPG, GIF 또는 PNG. 최대 2MB
                </p>
              </div>
            </div>
          </div>

          <!-- 이름 필드 -->
          <div>
            <%= form.label :full_name, "이름", class: "block text-sm font-medium text-slate-700 mb-2" %>
            <%= form.text_field :full_name, 
                class: "w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]",
                placeholder: "홍길동" %>
            <% if @user.errors[:full_name].any? %>
              <p class="mt-2 text-sm text-red-600">
                <%= @user.errors[:full_name].first %>
              </p>
            <% end %>
          </div>

          <!-- 이메일 필드 -->
          <div>
            <%= form.label :email, "이메일", class: "block text-sm font-medium text-slate-700 mb-2" %>
            <%= form.email_field :email, 
                class: "w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75]",
                placeholder: "your@email.com" %>
            <% if @user.errors[:email].any? %>
              <p class="mt-2 text-sm text-red-600">
                <%= @user.errors[:email].first %>
              </p>
            <% end %>
          </div>
        </div>

        <!-- 액션 버튼 -->
        <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-end space-x-3 rounded-b-lg">
          <%= link_to "취소", profile_path, 
              class: "px-4 py-2 border border-slate-300 rounded-md shadow-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#FF6D75]" %>
          
          <%= form.submit "변경사항 저장", 
              class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[#FF6D75] hover:bg-[#E85560] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#FF6D75] cursor-pointer" %>
        </div>
      </div>
    <% end %>

  </div>
</div>

<script>
function previewAvatar(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    
    reader.onload = function(e) {
      const preview = document.getElementById('avatar-preview');
      preview.innerHTML = `<img src="${e.target.result}" alt="Avatar preview" class="h-20 w-20 rounded-full object-cover">`;
    }
    
    reader.readAsDataURL(input.files[0]);
  }
}
</script>