<div class="text-center space-y-2">
  <%- if controller_name != 'sessions' %>
    <%= link_to "로그인", new_session_path(resource_name), class: "font-medium text-[#FF6D75] hover:text-[#FF8A92]" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "회원가입", new_registration_path(resource_name), class: "font-medium text-[#FF6D75] hover:text-[#FF8A92]" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <div class="mt-2">
      <%= link_to "비밀번호를 잊으셨나요?", new_password_path(resource_name), class: "text-sm text-gray-600 hover:text-gray-500" %>
    </div>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <div class="mt-2">
      <%= link_to "이메일 인증을 받지 못하셨나요?", new_confirmation_path(resource_name), class: "text-sm text-gray-600 hover:text-gray-500" %>
    </div>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <div class="mt-2">
      <%= link_to "계정 잠금 해제 안내를 받지 못하셨나요?", new_unlock_path(resource_name), class: "text-sm text-gray-600 hover:text-gray-500" %>
    </div>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "#{OmniAuth::Utils.camelize(provider)}로 로그인", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "mt-2 w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#FF6D75]" %>
    <% end %>
  <% end %>
</div>
