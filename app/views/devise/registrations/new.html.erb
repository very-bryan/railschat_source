<!-- Logo and Header -->
<div class="text-center mb-8">
  <div class="inline-flex items-center justify-center w-12 h-12 bg-gradient-to-br from-[#FF8A92] to-[#FF6D75] rounded-xl shadow-lg mb-4">
    <span class="text-white font-bold text-lg">W</span>
  </div>
  <h1 class="text-2xl font-bold text-slate-900">회원가입</h1>
  <p class="mt-2 text-sm text-slate-600">워크스페이스를 만들고 팀과 협업하세요</p>
</div>

<!-- Sign Up Form -->
<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :first_name, "이름", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :first_name, 
          autofocus: true,
          placeholder: "길동",
          class: "w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75] placeholder:text-slate-400" %>
    </div>
    
    <div>
      <%= f.label :last_name, "성", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :last_name,
          placeholder: "홍",
          class: "w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75] placeholder:text-slate-400" %>
    </div>
  </div>

  <div>
    <%= f.label :email, "이메일", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.email_field :email, 
        autocomplete: "email",
        placeholder: "your@email.com",
        class: "w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75] placeholder:text-slate-400" %>
  </div>

  <div>
    <%= f.label :password, "비밀번호", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.password_field :password, 
        autocomplete: "new-password",
        placeholder: "최소 6자 이상",
        class: "w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75] placeholder:text-slate-400" %>
    <% if @minimum_password_length %>
      <p class="mt-1 text-xs text-slate-500">최소 <%= @minimum_password_length %>자 이상</p>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, "비밀번호 확인", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.password_field :password_confirmation, 
        autocomplete: "new-password",
        placeholder: "비밀번호 재입력",
        class: "w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#FF6D75] focus:border-[#FF6D75] placeholder:text-slate-400" %>
  </div>

  <div>
    <%= f.submit "가입하기", 
        class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-[#FF6D75] hover:bg-[#FF8A92] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#FF6D75] transition-all transform hover:scale-[1.02] cursor-pointer" %>
  </div>
<% end %>

<!-- Divider -->
<div class="mt-6">
  <div class="relative">
    <div class="absolute inset-0 flex items-center">
      <div class="w-full border-t border-slate-200"></div>
    </div>
    <div class="relative flex justify-center text-sm">
      <span class="px-2 bg-white text-slate-500">또는</span>
    </div>
  </div>
</div>

<!-- Google Sign Up Button -->
<div class="mt-6">
  <%= button_to user_google_oauth2_omniauth_authorize_path, 
      method: :post,
      data: { turbo: false },
      class: "w-full flex items-center justify-center gap-3 px-4 py-2.5 border border-slate-200 rounded-lg text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#FF6D75] transition-all transform hover:scale-[1.02]" do %>
    <svg class="w-5 h-5" viewBox="0 0 24 24">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      <path fill="none" d="M1 1h22v22H1z"/>
    </svg>
    Google로 시작하기
  <% end %>
</div>

<div class="mt-8 text-center">
  <p class="text-sm text-slate-600">
    이미 계정이 있으신가요?
    <%= link_to "로그인", new_user_session_path, class: "font-medium text-[#FF6D75] hover:text-[#FF8A92]" %>
  </p>
</div>

<!-- Terms -->
<p class="mt-6 text-center text-xs text-slate-500">
  가입을 진행하면 
  <a href="#" class="underline hover:text-slate-700">서비스 약관</a> 및 
  <a href="#" class="underline hover:text-slate-700">개인정보 처리방침</a>에 동의한 것으로 간주됩니다.
</p>