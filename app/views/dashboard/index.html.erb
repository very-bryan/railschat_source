<% content_for :page_title, "대시보드" %>

<div class="space-y-6">
  <!-- Header -->
  <div class="mb-6">
    <p class="text-sm text-slate-500">오늘의 업무 현황을 한눈에 확인하세요</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <!-- 전체 노트 -->
    <div class="bg-white rounded-xl p-6 border border-slate-100 hover:shadow-md transition-all">
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-slate-600 font-medium">전체 노트</p>
        <div class="p-2 bg-[#FFF0F1] rounded-lg">
          <%= icon "file-text", library: "tabler", class: "w-5 h-5 text-[#FF6D75]" %>
        </div>
      </div>
      <div class="space-y-1">
        <h3 class="text-3xl font-bold text-slate-900">
          <%= number_with_delimiter(Note.where(workspace: current_user.current_workspace).count) %>
        </h3>
        <p class="text-xs text-emerald-600 font-medium">
          +12% 지난 달 대비
        </p>
      </div>
    </div>

    <!-- 활성 채널 -->
    <div class="bg-white rounded-xl p-6 border border-slate-100 hover:shadow-md transition-all">
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-slate-600 font-medium">활성 채널</p>
        <div class="p-2 bg-purple-50 rounded-lg">
          <%= icon "message-circle", library: "tabler", class: "w-5 h-5 text-purple-600" %>
        </div>
      </div>
      <div class="space-y-1">
        <h3 class="text-3xl font-bold text-slate-900">
          <%= number_with_delimiter(current_user.channels.count) %>
        </h3>
        <p class="text-xs text-emerald-600 font-medium">
          +5% 지난 달 대비
        </p>
      </div>
    </div>

    <!-- 팀 멤버 -->
    <div class="bg-white rounded-xl p-6 border border-slate-100 hover:shadow-md transition-all">
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-slate-600 font-medium">팀 멤버</p>
        <div class="p-2 bg-amber-50 rounded-lg">
          <%= icon "users", library: "tabler", class: "w-5 h-5 text-amber-600" %>
        </div>
      </div>
      <div class="space-y-1">
        <h3 class="text-3xl font-bold text-slate-900">
          <%= number_with_delimiter(User.count) %>
        </h3>
        <p class="text-xs text-amber-600 font-medium">
          +2 지난 달 대비
        </p>
      </div>
    </div>

    <!-- 완료율 -->
    <div class="bg-white rounded-xl p-6 border border-slate-100 hover:shadow-md transition-all">
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-slate-600 font-medium">완료율</p>
        <div class="p-2 bg-emerald-50 rounded-lg">
          <%= icon "trending-up", library: "tabler", class: "w-5 h-5 text-emerald-600" %>
        </div>
      </div>
      <div class="space-y-1">
        <h3 class="text-3xl font-bold text-slate-900">
          <% done_count = Note.joins(:status).where(statuses: { name: 'Done' }, workspace: current_user.current_workspace).count %>
          <% total_count = Note.where(workspace: current_user.current_workspace).count %>
          <%= total_count > 0 ? ((done_count.to_f / total_count * 100).round) : 0 %>%
        </h3>
        <p class="text-xs text-emerald-600 font-medium">
          +8% 지난 달 대비
        </p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- 상태별 노트 현황 -->
    <div class="bg-white rounded-xl border border-slate-100">
      <div class="p-6 border-b border-slate-100">
        <h3 class="text-base font-semibold text-slate-900">상태별 노트 현황</h3>
        <p class="text-sm text-slate-500 mt-1">전체 노트의 상태별 분포</p>
      </div>
      <div class="p-6 space-y-4">
        <% 
          statuses = current_user.current_workspace.statuses
          max_count = 200
        %>
        <% statuses.each do |status| %>
          <% count = Note.where(status: status, workspace: current_user.current_workspace).count %>
          <% percentage = max_count > 0 ? (count.to_f / max_count * 100) : 0 %>
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full" style="background-color: <%= status.color %>"></div>
                <span class="text-sm font-medium text-slate-700"><%= status.name %></span>
              </div>
              <span class="text-sm text-slate-600 font-medium"><%= count %></span>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-2">
              <div class="h-2 rounded-full transition-all duration-300" 
                   style="width: <%= [percentage, 100].min %>%; background-color: <%= status.color %>"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 최근 메시지 -->
    <div class="bg-white rounded-xl border border-slate-100">
      <div class="p-6 border-b border-slate-100 flex items-center justify-between">
        <div>
          <h3 class="text-base font-semibold text-slate-900">최근 메시지</h3>
          <p class="text-sm text-slate-500 mt-1">채널별 최근 대화</p>
        </div>
        <%= link_to chat_path, class: "text-sm text-[#FF6D75] hover:text-[#E85560] font-medium flex items-center gap-1" do %>
          전체 보기
          <%= icon "arrow-right", library: "tabler", class: "w-4 h-4" %>
        <% end %>
      </div>
      <div class="divide-y divide-slate-100">
        <% if current_user.channels.any? %>
          <% Message.includes(:user, :channel).where(channel_id: current_user.channel_ids).limit(3).order(created_at: :desc).each do |message| %>
            <div class="p-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-slate-200 rounded-full flex items-center justify-center flex-shrink-0">
                  <span class="text-xs font-medium text-slate-600">
                    <%= message.user.full_name.present? ? message.user.full_name.first.upcase : message.user.email.first.upcase %>
                  </span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h4 class="text-sm font-medium text-slate-900 truncate">
                      <%= message.user.full_name.present? ? message.user.full_name : message.user.email %>
                    </h4>
                    <span class="text-xs text-slate-500">#<%= message.channel.name %></span>
                  </div>
                  <p class="text-sm text-slate-600 line-clamp-2">
                    <%= truncate(message.body, length: 100) %>
                  </p>
                  <p class="text-xs text-slate-400 mt-1">
                    <%= time_ago_in_words(message.created_at) %> 전
                  </p>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="p-6 text-center">
            <p class="text-sm text-slate-500">아직 메시지가 없습니다</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 다가오는 마감일과 최근 활동 섹션 -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
    <!-- 다가오는 마감일 -->
    <div class="bg-white rounded-xl border border-slate-100">
      <div class="p-6 border-b border-slate-100">
        <h3 class="text-base font-semibold text-slate-900">다가오는 마감일</h3>
      </div>
      <div class="p-6">
      <% if @upcoming_deadlines.any? %>
        <div class="space-y-3">
          <% @upcoming_deadlines.each do |note| %>
            <div class="flex items-center justify-between p-4 hover:bg-slate-50 rounded-lg transition-colors">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full" style="background-color: <%= note.category.color %>"></div>
                <div>
                  <%= link_to note.title, note_path(note), class: "text-sm font-medium text-slate-900 hover:text-[#FF6D75] transition-colors" %>
                  <p class="text-xs text-slate-500"><%= note.category.name %></p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium <%= note.due_date < Date.current ? 'text-red-600' : note.due_date <= Date.current + 1.day ? 'text-amber-600' : 'text-slate-600' %>">
                  <%= note.due_date.strftime('%m/%d') %>
                </p>
                <p class="text-xs text-slate-500">
                  <%= note.due_date < Date.current ? '지연됨' : "#{(note.due_date - Date.current).to_i}일 후" %>
                </p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8 text-slate-500">
          <%= icon "calendar", library: "tabler", class: "w-12 h-12 text-slate-300 mx-auto mb-2" %>
          <p class="text-sm">다가오는 마감일이 없습니다</p>
        </div>
      <% end %>
      </div>
    </div>

    <!-- 최근 활동 -->
    <div class="bg-white rounded-xl border border-slate-100">
      <div class="p-6 border-b border-slate-100">
        <h3 class="text-base font-semibold text-slate-900">최근 활동</h3>
      </div>
      <div class="p-6">
      <% if @recent_notes.any? %>
        <div class="space-y-3">
          <% @recent_notes.each do |note| %>
            <div class="flex items-center gap-3 p-4 hover:bg-slate-50 rounded-lg transition-colors">
              <div class="w-2 h-2 rounded-full" style="background-color: <%= note.category.color %>"></div>
              <div class="flex-1">
                <%= link_to note.title, note_path(note), class: "text-sm font-medium text-slate-900 hover:text-[#FF6D75] transition-colors" %>
                <div class="flex items-center gap-2 mt-1">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium"
                        style="background-color: <%= note.status.color %>15; color: <%= note.status.color %>;">
                    <%= note.status.name %>
                  </span>
                  <span class="text-xs text-slate-500">
                    <%= time_ago_in_words(note.created_at) %> 전
                  </span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8 text-slate-500">
          <%= icon "clipboard-check", library: "tabler", class: "w-12 h-12 text-slate-300 mx-auto mb-2" %>
          <p class="text-sm">최근 활동이 없습니다</p>
        </div>
      <% end %>
      </div>
    </div>
  </div>
</div>